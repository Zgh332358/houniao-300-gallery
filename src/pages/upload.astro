---
/**
 * 老 /upload/ 入口现在重定向到向导第一步 /upload/setup/。
 * 写成 meta refresh + JS 双保险,静态托管(GH Pages)也能用。
 */
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
const target = `${base}/upload/setup/`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<title>跳转到上传向导...</title>
		<meta http-equiv="refresh" content={`0; url=${target}`} />
		<link rel="canonical" href={target} />
		<style>
			body {
				font-family:
					-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
				color: #555;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 70vh;
				margin: 0;
			}
			a {
				color: #7c3aed;
			}
		</style>
	</head>
	<body>
		<p>
			正在跳转... 如果浏览器没自动跳,
			<a href={target}>点这里继续</a>
		</p>
		<script
			is:inline
			define:vars={{ target }}
		>
			location.replace(target);
		</script>
	</body>
</html>
