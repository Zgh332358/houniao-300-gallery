---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout>
	<section class="pt-32 pb-20">
		<div class="container-custom max-w-3xl mx-auto">
			<div class="text-center mb-12">
				<h1 class="text-4xl md:text-5xl font-bold mb-4">分享你的作品</h1>
				<p class="text-gray-600">
					填写名字 + 联系方式 → 选作品集 → 上传图片，无需注册。 别人在
					<code class="px-2 py-0.5 bg-gray-100 rounded text-sm">/&lt;你的-slug&gt;</code> 即可看到你的作品。
				</p>
			</div>

			<div id="upload-app" x-data="uploadApp()" x-init="init()" class="space-y-8">
				<!-- mode 提示 -->
				<template x-if="mode === 'mock'">
					<div class="border border-blue-200 bg-blue-50 text-blue-900 p-4 rounded-lg text-sm">
						🎨 <strong>演示模式</strong> — 当前未配置 Supabase。上传会模拟成功并保存到本地浏览器（localStorage），
						刷新后仍可在 <code>/&lt;slug&gt;</code> 看到。要真实部署请按 README 配置 Supabase。
					</div>
				</template>

				<!-- AI 设置：自带 API Key -->
				<section class="border rounded-lg p-6" :class="aiOn ? 'border-violet-200 bg-violet-50/40' : 'border-gray-200'">
					<div class="flex items-center justify-between mb-1">
						<div class="flex items-center gap-2">
							<span class="text-lg">✨</span>
							<h2 class="text-xl font-semibold">AI 作品助手</h2>
							<span
								class="text-xs px-2 py-0.5 rounded-full"
								:class="aiOn ? 'bg-violet-100 text-violet-700' : 'bg-gray-100 text-gray-500'"
								x-text="aiOn ? '已启用' : '未启用'"
							></span>
						</div>
						<button
							type="button"
							class="text-xs text-gray-400 hover:text-gray-700"
							@click="aiSettingsOpen = !aiSettingsOpen"
							x-text="aiSettingsOpen ? '收起' : (aiOn ? '设置' : '展开设置')"
						></button>
					</div>
					<p class="text-xs text-gray-500 mb-4">
						填入你<strong>自己领取的 Step API Key</strong>，即可用多模态模型自动生成文案、对话润色，并在发布前做内容审核。
						Key 只保存在你本机浏览器，不会上传到任何服务器。
					</p>

					<div x-show="aiSettingsOpen || !aiOn" class="space-y-4">
						<div>
							<label class="block text-sm text-gray-600 mb-1">Step API Key *</label>
							<div class="flex gap-2">
								<input
									:type="showKey ? 'text' : 'password'"
									x-model="apiKey"
									@input="persistAi()"
									@change="onKeyCommitted()"
									placeholder="粘贴你的 StepFun API Key（sk-... 或一长串字符）"
									autocomplete="off"
									class="flex-1 px-3 py-2 border border-gray-300 rounded font-mono text-sm focus:outline-none focus:border-violet-500"
								/>
								<button
									type="button"
									@click="showKey = !showKey"
									class="px-3 py-2 border border-gray-300 rounded text-sm text-gray-500 hover:text-gray-800"
									x-text="showKey ? '隐藏' : '显示'"
								></button>
							</div>
							<p class="text-xs text-gray-500 mt-1">
								没有 key？去
								<a href="https://platform.stepfun.com/" target="_blank" rel="noopener" class="underline hover:text-violet-700">StepFun 开放平台</a>
								领取。
							</p>
						</div>
						<div>
							<label class="block text-sm text-gray-600 mb-1">模型</label>
							<input
								type="text"
								x-model="model"
								@input="persistAi()"
								placeholder="step-3.7-flash"
								class="w-full px-3 py-2 border border-gray-300 rounded font-mono text-sm focus:outline-none focus:border-violet-500"
							/>
							<p class="text-xs text-gray-500 mt-1">默认 <code>step-3.7-flash</code>（多模态）。可改成其它支持图像理解的模型。</p>
						</div>
					</div>
				</section>

				<!-- STEP 1: 身份 -->
				<section class="border border-gray-200 rounded-lg p-6">
					<div class="flex items-center mb-4">
						<span
							class="w-7 h-7 rounded-full bg-black text-white flex items-center justify-center text-sm font-semibold mr-3"
							>1</span
						>
						<h2 class="text-xl font-semibold">你是谁</h2>
					</div>
					<div class="space-y-4">
						<div>
							<label class="block text-sm text-gray-600 mb-1">显示名 *</label>
							<input
								type="text"
								x-model="artistName"
								@input="recomputeSlug()"
								placeholder="你的名字 / 笔名"
								class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-black"
							/>
							<p class="text-xs text-gray-500 mt-1.5" x-show="artistSlug">
								你的页面地址：<code class="px-1.5 py-0.5 bg-gray-100 rounded text-gray-700 font-mono" x-text="`/${artistSlug}/`"></code>
							</p>
						</div>
						<div>
							<label class="block text-sm text-gray-600 mb-1">联系方式 *</label>
							<input
								type="text"
								x-model="artistContact"
								placeholder="email@example.com 或 @your_ig 或 https://..."
								class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-black"
							/>
							<p class="text-xs text-gray-500 mt-1">仅供运营私下回联,不会公开展示在你的作品页上</p>
						</div>
					</div>
				</section>

				<!-- STEP 1.5: 你的声音(可选,但启用后才有 AI 解说音频) -->
				<section
					class="border rounded-lg p-6"
					:class="(step1Done ? '' : 'opacity-60 ') + (voiceState === 'done' ? 'border-violet-200 bg-violet-50/40' : 'border-gray-200')"
				>
					<div class="flex items-center justify-between mb-1">
						<div class="flex items-center gap-2">
							<span class="text-lg">🎙️</span>
							<h2 class="text-xl font-semibold">你的声音</h2>
							<span
								x-show="voiceState === 'done'"
								class="text-xs px-2 py-0.5 rounded-full bg-violet-100 text-violet-700"
							>已登记</span>
							<span
								x-show="voiceState !== 'done'"
								class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500"
							>可选</span>
						</div>
					</div>
					<p class="text-xs text-gray-500 mb-4">
						对着麦克风<strong>朗读下面这句话</strong>,AI 会用这段录音克隆你的音色 ——
						之后你发布作品时,会自动生成「你的声音」念出来的语音解说。
						没录也能发作品,但访客就听不到「艺术家亲口讲这幅画」了。
					</p>

					<!-- 提示词 -->
					<div
						class="mb-4 p-4 bg-gray-50 border-l-4 border-violet-400 rounded-r"
						x-show="voiceState !== 'done'"
					>
						<p class="text-xs text-gray-500 mb-1">请朗读 ↓</p>
						<p class="text-base md:text-lg leading-relaxed text-gray-800">
							「如果你听到我的声音,说明你正在看我的作品。慢慢看,慢慢听。」
						</p>
						<p class="text-xs text-gray-400 mt-2">约 6~8 秒 · 自然语速 · 不要刻意</p>
					</div>

					<!-- A: 录音按钮 + 已录音预览 -->
					<div x-show="voiceState === 'idle' || voiceState === 'recorded' || voiceState === 'error'" class="space-y-3">
						<div class="flex items-center gap-3">
							<button
								type="button"
								x-show="!recording"
								@click="startRecording()"
								:disabled="!step1Done || !aiOn"
								class="px-5 py-3 rounded-full bg-violet-600 text-white font-medium hover:bg-violet-700 disabled:bg-gray-300 disabled:cursor-not-allowed flex items-center gap-2"
							>
								<span class="w-2.5 h-2.5 bg-white rounded-full"></span>
								<span x-text="voiceFile ? '重新录' : '开始录音'"></span>
							</button>
							<button
								type="button"
								x-show="recording"
								@click="stopRecording()"
								class="px-5 py-3 rounded-full bg-red-600 text-white font-medium hover:bg-red-700 flex items-center gap-2"
							>
								<span class="w-2.5 h-2.5 bg-white rounded-sm animate-pulse"></span>
								停止 (<span x-text="recordSecs.toFixed(1)"></span>s)
							</button>
							<span x-show="recording" class="text-xs text-gray-500">
								12 秒后自动停;听到后默念「慢慢看,慢慢听」时再停最自然
							</span>
						</div>

						<div x-show="voiceFileUrl && !recording" class="space-y-2">
							<audio :src="voiceFileUrl" controls class="w-full"></audio>
							<p class="text-xs text-gray-500">
								录到 <span x-text="voiceFileDuration"></span> · 听一下满意吗?不满意点上面「重新录」
							</p>
						</div>

						<label
							x-show="voiceFile && !recording"
							class="flex items-start gap-2 text-sm text-gray-700 select-none cursor-pointer"
						>
							<input type="checkbox" x-model="voiceConsent" class="mt-1" />
							<span>
								我授权该平台使用这段录音克隆<strong>我本人</strong>的声音,仅用于本平台为我的作品生成 AI 解说语音。
							</span>
						</label>

						<button
							type="button"
							x-show="voiceFile && !recording"
							:disabled="!canRegisterVoice"
							@click="registerVoice()"
							class="px-4 py-2 bg-violet-600 text-white rounded text-sm font-medium hover:bg-violet-700 disabled:bg-gray-300 disabled:cursor-not-allowed"
						>登记我的音色</button>

						<p x-show="voiceError" class="text-sm text-red-600" x-text="voiceError"></p>

						<template x-if="voiceState === 'idle' && !aiOn">
							<p class="text-xs text-amber-700">
								需要先在上方「AI 作品助手」填好 Step API Key 才能调用音色复刻。
							</p>
						</template>
						<template x-if="voiceState === 'idle' && aiOn && !step1Done">
							<p class="text-xs text-amber-700">
								先在「你是谁」填好显示名,再录音 — 我们要把声音绑到你的页面。
							</p>
						</template>
					</div>

					<!-- B: 复刻中 -->
					<div x-show="voiceState === 'registering'" class="text-sm text-violet-700">
						正在复刻你的音色...通常 5~15 秒。
					</div>

					<!-- C: 试听确认 -->
					<div x-show="voiceState === 'previewing'" class="space-y-3">
						<p class="text-sm">
							已生成你的克隆音色试听。听一下像不像你 ——
						</p>
						<audio :src="voiceSampleUrl" controls class="w-full"></audio>
						<div class="flex gap-2">
							<button
								type="button"
								@click="confirmVoice()"
								class="px-4 py-2 bg-violet-600 text-white rounded text-sm font-medium hover:bg-violet-700"
							>就用它</button>
							<button
								type="button"
								@click="resetVoice()"
								class="px-4 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50"
							>重录</button>
						</div>
					</div>

					<!-- D: 已登记 -->
					<div x-show="voiceState === 'done'" class="space-y-2">
						<p class="text-sm text-violet-800">
							✅ 已登记你的克隆音色。发布作品时,AI 会用这个声音念解说词。
						</p>
						<p class="text-xs text-gray-500 font-mono break-all">voice_id: <span x-text="voiceId"></span></p>
						<button
							type="button"
							@click="resetVoice()"
							class="text-xs text-gray-500 underline hover:text-gray-800"
						>换一段录音重做</button>
					</div>
				</section>
				<section
					class="border border-gray-200 rounded-lg p-6"
					:class="step1Done ? '' : 'opacity-60'"
				>
					<div class="flex items-center mb-4">
						<span
							class="w-7 h-7 rounded-full bg-black text-white flex items-center justify-center text-sm font-semibold mr-3"
							>2</span
						>
						<h2 class="text-xl font-semibold">作品集</h2>
					</div>
					<div class="space-y-4">
						<div>
							<label class="block text-sm text-gray-600 mb-1">作品集名 *</label>
							<input
								type="text"
								x-model="collectionName"
								@input="recomputeCollSlug()"
								placeholder="作品集名称（如：人像 / 街拍 / 旅行）"
								class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-black"
							/>
							<p class="text-xs text-gray-500 mt-1.5">同一作品集名下的图片会被分到同一个标签页里</p>
						</div>
					</div>
				</section>

				<!-- STEP 3: 选图 -->
				<section
					class="border border-gray-200 rounded-lg p-6"
					:class="step2Done ? '' : 'opacity-60'"
				>
					<div class="flex items-center mb-4">
						<span
							class="w-7 h-7 rounded-full bg-black text-white flex items-center justify-center text-sm font-semibold mr-3"
							>3</span
						>
						<h2 class="text-xl font-semibold">选择图片</h2>
					</div>

					<div class="mb-4 space-y-2">
						<p x-show="aiOn" class="text-sm text-violet-700 bg-violet-50 border border-violet-100 rounded-lg px-3 py-2 flex items-start gap-2">
							<span>✨</span>
							<span>拖入图片后，<strong x-text="model"></strong> 会自动读图、做内容审核，并生成标题 / 描述 / 标签 / 策展评语；你还能在每张图下方<strong>和模型对话</strong>来调整文案。审核未通过的作品将无法发布。</span>
						</p>
						<p x-show="!aiOn" class="text-sm text-amber-700 bg-amber-50 border border-amber-100 rounded-lg px-3 py-2 flex items-start gap-2">
							<span>🔑</span>
							<span>想让 AI 帮你写文案、并在发布前自动审核？请先在上方
								<button type="button" class="underline" @click="aiSettingsOpen = true">「AI 作品助手」</button>
								填入你自己的 Step API Key。</span>
						</p>
						<button
							type="button"
							x-show="aiOn && files.some(x => x.ai.status === 'hidden')"
							@click="analyzeAllPending()"
							class="text-xs px-3 py-1.5 border border-violet-300 text-violet-700 rounded hover:bg-violet-50"
						>✨ 用 AI 分析未处理的 <span x-text="files.filter(x => x.ai.status === 'hidden').length"></span> 张</button>
					</div>

					<label
						class="block border-2 border-dashed border-gray-300 hover:border-gray-500 rounded-lg p-12 text-center cursor-pointer transition-colors"
						:class="dragOver ? 'border-black bg-gray-50' : ''"
						@dragover.prevent="dragOver = true"
						@dragleave.prevent="dragOver = false"
						@drop.prevent="dragOver = false; addFiles($event.dataTransfer.files)"
					>
						<input
							type="file"
							accept="image/*"
							multiple
							class="sr-only"
							@change="addFiles($event.target.files); $event.target.value = ''"
						/>
						<div class="text-gray-500">
							<svg class="mx-auto h-12 w-12 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M7 16a4 4 0 01-.88-7.9 5 5 0 019.9-1A5.5 5.5 0 0118 16M9 19l3-3m0 0l3 3m-3-3v6"></path>
							</svg>
							<p class="font-medium">点击选择图片，或拖拽到此</p>
							<p class="text-sm mt-1">支持多选 · JPG/PNG/WebP</p>
						</div>
					</label>

					<!-- 文件列表 -->
					<div class="mt-6 space-y-3" x-show="files.length > 0">
						<template x-for="(f, idx) in files" :key="f.id">
							<div class="flex flex-col sm:flex-row sm:items-start gap-3 sm:gap-4 border border-gray-200 rounded p-3">
								<img :src="f.preview" class="w-full sm:w-24 h-40 sm:h-24 object-cover rounded" />
								<div class="flex-1 space-y-2">
									<input
										type="text"
										x-model="f.title"
										@input="f.titleEdited = true"
										placeholder="中文标题"
										class="w-full px-2 py-1 text-sm border border-gray-200 rounded"
									/>
									<input
										type="text"
										x-model="f.titleEn"
										placeholder="English title (AI 自动填,可改)"
										class="w-full px-2 py-1 text-sm border border-gray-200 rounded text-gray-600"
									/>
									<input
										type="text"
										x-model="f.description"
										@input="f.descEdited = true"
										placeholder="中文描述(可选)"
										class="w-full px-2 py-1 text-sm border border-gray-200 rounded"
									/>
									<input
										type="text"
										x-model="f.descriptionEn"
										placeholder="English description (AI 自动填,可改)"
										class="w-full px-2 py-1 text-sm border border-gray-200 rounded text-gray-600"
									/>

									<!-- ✨ Step 作品助手 -->
									<div x-show="f.ai.status !== 'hidden'" class="border-t border-gray-100 pt-2">
										<!-- 分析中 -->
										<div x-show="f.ai.status === 'loading'" class="flex items-center gap-2 text-xs text-violet-600">
											<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24">
												<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
												<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.4 0 0 5.4 0 12h4z"></path>
											</svg>
											<span>模型正在读这张作品并做审核…</span>
										</div>

										<!-- 失败 -->
										<div x-show="f.ai.status === 'error'" class="flex items-center gap-2 text-xs text-red-500">
											<span x-text="f.ai.error"></span>
											<button @click="analyzeOne(f)" class="underline hover:text-red-700">重试</button>
										</div>

										<!-- 完成 -->
										<div x-show="f.ai.status === 'done'" class="space-y-2">
											<div class="flex items-center gap-2 text-xs">
												<span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-violet-100 text-violet-700 font-medium">✨ <span x-text="model"></span></span>
												<button @click="analyzeOne(f)" class="ml-auto text-gray-400 hover:text-violet-600">↻ 重新生成</button>
											</div>

											<!-- 内容审核结果（门控发布） -->
											<div
												x-show="f.moderation && f.moderation.safe === false"
												class="flex items-start gap-2 text-xs bg-red-50 border border-red-200 text-red-700 rounded p-2"
											>
												<span>⛔</span>
												<span>
													<strong>内容审核未通过，该作品无法发布。</strong>
													<span x-show="f.moderation && f.moderation.reason" x-text="'　' + (f.moderation ? f.moderation.reason : '')"></span>
													<template x-if="f.moderation && f.moderation.categories && f.moderation.categories.length">
														<span> · <span x-text="f.moderation.categories.join('、')"></span></span>
													</template>
												</span>
											</div>
											<div
												x-show="f.moderation && f.moderation.safe !== false"
												class="flex items-center gap-1 text-xs text-green-600"
											>
												✓ 内容审核通过
											</div>

											<!-- 标签 -->
											<div class="flex flex-wrap gap-1.5">
												<template x-for="t in tagList(f.ai.suggestion)" :key="t.k">
													<span class="px-2 py-0.5 rounded-full bg-violet-50 text-violet-700 text-xs border border-violet-100" x-text="t.v"></span>
												</template>
											</div>

											<!-- 策展人评语 -->
											<p
												x-show="f.ai.suggestion && f.ai.suggestion.curatorNote"
												class="text-xs text-gray-600 italic border-l-2 border-violet-200 pl-2"
											>
												“<span x-text="f.ai.suggestion.curatorNote"></span>” —— AI 策展助理
											</p>

											<!-- 思考过程（秀多模态推理） -->
											<div x-show="f.ai.reasoning">
												<button
													@click="f.ai.showReasoning = !f.ai.showReasoning"
													class="text-xs text-gray-400 hover:text-gray-600"
												>
													🧠 <span x-text="f.ai.showReasoning ? '收起思考过程' : '看它怎么想的'"></span>
												</button>
												<pre
													x-show="f.ai.showReasoning"
													class="mt-1 text-[11px] leading-relaxed text-gray-500 whitespace-pre-wrap bg-gray-50 rounded p-2 max-h-40 overflow-auto"
													x-text="f.ai.reasoning"
												></pre>
											</div>

											<!-- 💬 和模型对话调整文案 -->
											<div class="pt-1">
												<button
													@click="f.chat.open = !f.chat.open"
													class="text-xs text-violet-600 hover:text-violet-800 font-medium"
												>
													💬 <span x-text="f.chat.open ? '收起对话' : '和模型聊聊，调整文案'"></span>
												</button>
												<div x-show="f.chat.open" class="mt-2 border border-violet-100 rounded-lg bg-white overflow-hidden">
													<div class="max-h-52 overflow-auto p-2 space-y-2">
														<div
															x-show="f.chat.msgs.length === 0 && !f.chat.busy"
															class="text-xs text-gray-400 leading-relaxed"
														>
															例如：「标题更冷峻一点」「描述里强调光影」「换个更年轻的语气」「这张其实是夜景，重写一下」
														</div>
														<template x-for="(m, mi) in f.chat.msgs" :key="mi">
															<div :class="m.role === 'user' ? 'text-right' : 'text-left'">
																<span
																	class="inline-block px-2.5 py-1.5 rounded-2xl text-xs max-w-[85%] whitespace-pre-wrap text-left"
																	:class="m.role === 'user' ? 'bg-violet-600 text-white' : 'bg-gray-100 text-gray-700'"
																	x-text="m.text"
																></span>
															</div>
														</template>
														<div x-show="f.chat.busy" class="text-left">
															<span class="inline-block px-2.5 py-1.5 rounded-2xl text-xs bg-gray-100 text-gray-400">模型思考中…</span>
														</div>
													</div>
													<div class="flex gap-2 border-t border-gray-100 p-2">
														<input
															type="text"
															x-model="f.chat.input"
															@keydown.enter.prevent="sendChat(f)"
															:disabled="f.chat.busy"
															placeholder="告诉模型你想怎么改…"
															class="flex-1 px-2 py-1 text-sm border border-gray-200 rounded focus:outline-none focus:border-violet-400"
														/>
														<button
															@click="sendChat(f)"
															:disabled="f.chat.busy || !f.chat.input.trim()"
															class="px-3 py-1 text-sm bg-violet-600 text-white rounded disabled:bg-gray-300 disabled:cursor-not-allowed"
														>发送</button>
													</div>
												</div>
											</div>
										</div>
									</div>

									<div class="flex items-center justify-between text-xs text-gray-500">
										<span x-text="`${(f.size / 1024 / 1024).toFixed(2)} MB`"></span>
										<div class="flex items-center gap-3">
											<span x-show="f.status === 'uploading'" class="text-blue-600">
												上传中 <span x-text="f.progress + '%'"></span>
											</span>
											<span x-show="f.status === 'narrating'" class="text-violet-600">
												🎙️ 生成 AI 解说...
											</span>
											<span x-show="f.status === 'done' && f.narrationPath" class="text-violet-700">
												✓ 已上传 · 含语音解说
											</span>
											<span x-show="f.status === 'done' && !f.narrationPath" class="text-green-600">✓ 已上传</span>
											<span x-show="f.status === 'error'" class="text-red-600" x-text="f.error"></span>
											<button
												x-show="f.status === 'idle' || f.status === 'error'"
												@click="removeFile(idx)"
												class="text-gray-400 hover:text-red-600">移除</button>
										</div>
									</div>
								</div>
							</div>
						</template>
					</div>
				</section>

				<!-- 上传按钮 -->
				<div class="flex items-center justify-between gap-4">
					<button
						class="flex-1 py-3 bg-black text-white rounded font-medium disabled:bg-gray-300 disabled:cursor-not-allowed"
						:disabled="!canUpload"
						@click="startUpload()"
					>
						<span x-show="!uploading && pendingCount === 0">先选几张图</span>
						<span x-show="!uploading && pendingCount > 0 && !step2Done" class="text-xs">请先填完上方的姓名/联系方式/作品集</span>
						<span x-show="!uploading && pendingCount > 0 && step2Done && aiAnalyzing" class="text-xs">⏳ AI 审核中，请稍候…</span>
						<span x-show="!uploading && pendingCount > 0 && step2Done && !aiAnalyzing && aiBlocked" class="text-xs">⛔ 有作品未通过审核，移除后再发布</span>
						<span x-show="!uploading && pendingCount > 0 && step2Done && !aiAnalyzing && !aiBlocked" x-text="`发布 ${pendingCount} 张作品`"></span>
						<span x-show="uploading">上传中…</span>
					</button>
					<a
						x-show="doneCount > 0 && !uploading"
						:href="artistViewHref"
						class="px-6 py-3 border border-black rounded font-medium hover:bg-gray-50"
					>
						查看我的页面 →
					</a>
				</div>

				<p class="text-xs text-gray-500 text-center" x-show="doneCount > 0">
					已上传 <span x-text="doneCount"></span> 张
					<span x-show="mode === 'live'">· 由于 CDN 缓存，公开页面最长延迟 1 分钟显示</span>
					<span x-show="mode === 'mock'">· 数据仅保存在本浏览器，换设备不可见</span>
				</p>

				<!-- 发布成功后:个人页 URL + 一键复制 -->
				<div
					x-show="doneCount > 0 && !uploading && artistFullUrl"
					class="mt-3 max-w-2xl mx-auto p-4 bg-violet-50 border border-violet-200 rounded-lg"
				>
					<p class="text-sm text-violet-900 mb-2">🎉 你的作品页就在这里:</p>
					<div class="flex items-center gap-2">
						<input
							type="text"
							readonly
							:value="artistFullUrl"
							@click="$event.target.select()"
							class="flex-1 px-3 py-2 bg-white border border-violet-200 rounded font-mono text-xs text-gray-700 select-all"
						/>
						<button
							type="button"
							@click="copyArtistUrl()"
							class="px-3 py-2 bg-violet-600 text-white rounded text-xs font-medium hover:bg-violet-700 whitespace-nowrap"
							x-text="copied ? '✓ 已复制' : '复制链接'"
						></button>
					</div>
					<p class="text-xs text-violet-700 mt-2">
						把这个链接发给朋友、放在小红书简介里 — 任何人打开都能看到你的作品 + 听 AI 用你的声音讲解。
					</p>
				</div>
			</div>
		</div>
	</section>
</MainLayout>

<script>
	import {
		getMode,
		isValidSlug,
		saveMockUpload,
		toSlug,
		uploadPhoto,
		type PhotoEntry,
		type PhotoMeta,
		uploadNarrationMp3,
		setNarration,
	} from '../lib/photos';
	import {
		analyzePhoto,
		chatRevise,
		generateNarrationText,
		getAiConfig,
		setAiConfig,
		type AiSuggestion,
		type Moderation,
	} from '../lib/ai';
	import {
		uploadVoiceSample,
		cloneVoice,
		synthesizeSpeech,
		base64ToBlob,
	} from '../lib/ai-voice';
	import { blobToWav, pickRecorderMime } from '../lib/wav';
	import {
		upsertArtist,
		setArtistVoice,
		uploadVoiceSample as uploadVoiceSampleToBucket,
	} from '../lib/artists';

	interface AiState {
		status: 'hidden' | 'loading' | 'done' | 'error';
		suggestion: AiSuggestion | null;
		reasoning: string;
		error: string;
		showReasoning: boolean;
	}

	interface ChatState {
		open: boolean;
		busy: boolean;
		input: string;
		msgs: { role: 'user' | 'assistant'; text: string }[];
		/** 传给模型的内部对话上下文（含首轮图片），不直接展示 */
		history: any[];
	}

	interface FileItem {
		id: string;
		file: File;
		preview: string;
		title: string;
		titleEn: string;
		description: string;
		descriptionEn: string;
		titleEdited: boolean;
		descEdited: boolean;
		size: number;
		status: 'idle' | 'uploading' | 'narrating' | 'done' | 'error';
		progress: number;
		error: string;
		ai: AiState;
		moderation: Moderation | null;
		chat: ChatState;
		/** M3: 已上传后,本次会话生成的解说文本(供 UI 复读) */
		narrationText?: string;
		/** M3: 解说音频在 audio bucket 的路径 */
		narrationPath?: string;
	}

	const STORAGE_KEY = 'pf:identity:v1';
	const COLL_KEY = 'pf:lastColl:v1';
	const MOCK_DATA_URL_LIMIT = 800 * 1024; // mock 模式下仅 < 800KB 的文件存 base64

	function uploadApp() {
		const base = (import.meta.env.BASE_URL as string).replace(/\/+$/, '');

		return {
			mode: getMode() as 'live' | 'mock',
			base,
			artistName: '',
			artistSlug: '',
			artistContact: '',
			collectionName: '',
			collectionSlug: '',
			files: [] as FileItem[],
			uploading: false,
			dragOver: false,
			// BYOK：艺术家自带的 Step API Key / 模型
			apiKey: getAiConfig().apiKey,
			model: getAiConfig().model,
			showKey: false,
			aiSettingsOpen: false,

			// 🎙️ 声音登记 (M3)
			voiceState: 'idle' as 'idle' | 'recorded' | 'registering' | 'previewing' | 'done' | 'error',
			voiceFile: null as File | null,
			voiceFileUrl: '' as string,
			voiceFileDuration: '' as string,
			voiceConsent: false,
			voiceId: '' as string,
			voiceSamplePath: '' as string,
			voiceSampleUrl: '' as string,
			voiceError: '' as string,
			// 🎤 就地录音
			recording: false,
			recordSecs: 0 as number,
			_mediaRecorder: null as MediaRecorder | null,
			_mediaStream: null as MediaStream | null,
			_recordChunks: [] as Blob[],
			_recordTimer: 0 as number,
			_recordStartedAt: 0 as number,

			init() {
				try {
					const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
					if (saved) {
						this.artistName = saved.artistName || '';
						this.artistSlug = saved.artistSlug || '';
						this.artistContact = saved.artistContact || '';
						// slug 字段已对用户隐藏，把 saved 视作自动生成的 → 后续改名时会重算
						this._lastAutoSlug = this.artistSlug;
					}
					const lastColl = JSON.parse(localStorage.getItem(COLL_KEY) || 'null');
					if (lastColl) {
						this.collectionName = lastColl.name || '';
						this.collectionSlug = lastColl.slug || '';
						this._lastAutoCollSlug = this.collectionSlug;
					}
				} catch {}
				// 把这个 slug 之前登记过的音色还原回来
				this.restoreVoiceForCurrentSlug();
			},

			recomputeSlug() {
				if (!this.artistSlug || this._lastAutoSlug === this.artistSlug) {
					this.artistSlug = toSlug(this.artistName);
					this._lastAutoSlug = this.artistSlug;
					// slug 变了,重新看看新 slug 是否已经登记过音色
					this.restoreVoiceForCurrentSlug();
				}
			},
			recomputeCollSlug() {
				if (!this.collectionSlug || this._lastAutoCollSlug === this.collectionSlug) {
					this.collectionSlug = toSlug(this.collectionName);
					this._lastAutoCollSlug = this.collectionSlug;
				}
			},
			_lastAutoSlug: '',
			_lastAutoCollSlug: '',

			get step1Done() {
				return (
					this.artistName.trim().length > 0 &&
					isValidSlug(this.artistSlug) &&
					this.artistContact.trim().length > 0
				);
			},
			get step2Done() {
				return (
					this.step1Done &&
					this.collectionName.trim().length > 0 &&
					isValidSlug(this.collectionSlug)
				);
			},
			get pendingCount() {
				return this.files.filter((f: FileItem) => f.status === 'idle').length;
			},
			get doneCount() {
				return this.files.filter((f: FileItem) => f.status === 'done').length;
			},
			get aiOn() {
				return this.apiKey.trim().length > 0;
			},
			/** 有待发布的图仍在 AI 审核中 */
			get aiAnalyzing() {
				if (!this.aiOn) return false;
				return this.files.some((f: FileItem) => f.status === 'idle' && f.ai.status === 'loading');
			},
			/** 有待发布的图被判定为不适合传播 */
			get aiBlocked() {
				if (!this.aiOn) return false;
				return this.files.some(
					(f: FileItem) => f.status === 'idle' && f.moderation && f.moderation.safe === false,
				);
			},
			get canUpload() {
				if (!(this.step2Done && this.pendingCount > 0 && !this.uploading)) return false;
				if (this.aiOn) {
					// 开启 AI 时：待发布的每张图都必须完成审核且通过，否则不允许发布
					const pending = this.files.filter((f: FileItem) => f.status === 'idle');
					if (pending.some((f: FileItem) => f.ai.status !== 'done')) return false;
					if (this.aiBlocked) return false;
				}
				return true;
			},
			get artistViewHref() {
				if (this.mode === 'mock' && location.hostname === 'localhost') {
					return `${this.base}/__artist__/?slug=${this.artistSlug}`;
				}
				return `${this.base}/${this.artistSlug}/`;
			},

			/** 给艺术家展示「我的页面 URL」用 — 完整的 origin + base + slug */
			get artistFullUrl(): string {
				if (!this.artistSlug || typeof location === 'undefined') return '';
				return `${location.origin}${this.base}/${this.artistSlug}/`;
			},

			copied: false,
			async copyArtistUrl() {
				if (!this.artistFullUrl) return;
				try {
					await navigator.clipboard.writeText(this.artistFullUrl);
					this.copied = true;
					setTimeout(() => {
						this.copied = false;
					}, 1800);
				} catch {
					this.copied = false;
				}
			},

			addFiles(list: FileList | null) {
				if (!list) return;
				for (const file of Array.from(list)) {
					if (!file.type.startsWith('image/')) continue;
					this.files.push({
						id: Math.random().toString(36).slice(2),
						file,
						preview: URL.createObjectURL(file),
						title: stripExt(file.name),
						titleEn: '',
						description: '',
						descriptionEn: '',
						titleEdited: false,
						descEdited: false,
						size: file.size,
						status: 'idle',
						progress: 0,
						error: '',
						ai: {
							status: this.aiOn ? 'loading' : 'hidden',
							suggestion: null,
							reasoning: '',
							error: '',
							showReasoning: false,
						},
						moderation: null,
						chat: { open: false, busy: false, input: '', msgs: [], history: [] },
					});
					// 取回 Alpine 包装后的响应式引用再异步分析，确保 UI 更新
					if (this.aiOn) {
						const ref = this.files[this.files.length - 1];
						this.analyzeOne(ref);
					}
				}
			},

			persistAi() {
				setAiConfig({ apiKey: this.apiKey, model: this.model });
			},
			/** key 输入框失焦时：保存，并自动分析尚未处理的图 */
			onKeyCommitted() {
				this.persistAi();
				if (this.aiOn) this.analyzeAllPending();
			},

			/* ---------- 声音登记 (M3) ---------- */

			get canRegisterVoice() {
				return (
					this.voiceState !== 'registering' &&
					this.voiceState !== 'previewing' &&
					this.voiceState !== 'done' &&
					!!this.voiceFile &&
					this.voiceConsent &&
					this.aiOn
				);
			},

			onVoiceFilePicked(_ev: Event) {
				/* 旧的文件上传入口已删除,这里保留空实现避免老缓存的页面报错 */
			},

			async startRecording() {
				this.voiceError = '';
				if (!this.aiOn) {
					this.voiceError = '请先在上方「AI 助手」填入 Step API Key';
					return;
				}
				if (!this.step1Done) {
					this.voiceError = '请先在「你是谁」填好显示名';
					return;
				}
				if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
					this.voiceError = '当前浏览器不支持录音,请用 Chrome / Edge / Safari';
					return;
				}
				let stream: MediaStream;
				try {
					stream = await navigator.mediaDevices.getUserMedia({ audio: true });
				} catch (err: any) {
					this.voiceError =
						err?.name === 'NotAllowedError'
							? '麦克风权限被拒绝。请在浏览器地址栏左侧重新允许。'
							: `麦克风启动失败: ${err?.message || String(err)}`;
					return;
				}
				const mime = pickRecorderMime();
				let mr: MediaRecorder;
				try {
					mr = mime ? new MediaRecorder(stream, { mimeType: mime }) : new MediaRecorder(stream);
				} catch (err: any) {
					this.voiceError = `MediaRecorder 启动失败: ${err?.message || String(err)}`;
					stream.getTracks().forEach((t) => t.stop());
					return;
				}

				// 清掉上一次录音的预览
				if (this.voiceFileUrl) {
					URL.revokeObjectURL(this.voiceFileUrl);
					this.voiceFileUrl = '';
				}
				this.voiceFile = null;
				this._recordChunks = [];

				mr.addEventListener('dataavailable', (e: BlobEvent) => {
					if (e.data && e.data.size > 0) this._recordChunks.push(e.data);
				});
				mr.addEventListener('stop', () => {
					this._finalizeRecording();
				});

				this._mediaRecorder = mr;
				this._mediaStream = stream;
				this._recordStartedAt = performance.now();
				this.recordSecs = 0;
				mr.start();
				this.recording = true;

				// 倒计时 + 12s 自动停
				const tick = () => {
					if (!this.recording) return;
					this.recordSecs = (performance.now() - this._recordStartedAt) / 1000;
					if (this.recordSecs >= 12) {
						this.stopRecording();
						return;
					}
					this._recordTimer = window.setTimeout(tick, 100);
				};
				tick();
			},

			stopRecording() {
				if (!this.recording) return;
				this.recording = false;
				if (this._recordTimer) {
					clearTimeout(this._recordTimer);
					this._recordTimer = 0;
				}
				try {
					this._mediaRecorder?.stop();
				} catch {
					/* ignore */
				}
				try {
					this._mediaStream?.getTracks().forEach((t) => t.stop());
				} catch {
					/* ignore */
				}
				this._mediaStream = null;
			},

			async _finalizeRecording() {
				const recorder = this._mediaRecorder;
				this._mediaRecorder = null;
				if (!this._recordChunks.length) {
					this.voiceError = '没录到声音 — 检查麦克风或重试';
					return;
				}
				const recordedMime = recorder?.mimeType || this._recordChunks[0]?.type || 'audio/webm';
				const rawBlob = new Blob(this._recordChunks, { type: recordedMime });
				this._recordChunks = [];

				// 转 WAV(StepFun /v1/files 接受 wav)
				let wavBlob: Blob;
				try {
					wavBlob = await blobToWav(rawBlob);
				} catch (err: any) {
					this.voiceError = `录音转 WAV 失败: ${err?.message || String(err)}`;
					return;
				}

				// 给浏览器 audio 标签预览用 - 直接用原始 blob,WAV 文件留给 StepFun
				if (this.voiceFileUrl) URL.revokeObjectURL(this.voiceFileUrl);
				this.voiceFileUrl = URL.createObjectURL(rawBlob);

				// 把 WAV 包成 File,registerVoice 上传时要带文件名
				const filename = `${this.artistSlug || 'voice'}-${Date.now()}.wav`;
				this.voiceFile = new File([wavBlob], filename, { type: 'audio/wav' });

				// 试探时长 + 给 UI
				const duration = (performance.now() - this._recordStartedAt) / 1000;
				this.voiceFileDuration = `${duration.toFixed(1)} 秒`;
				if (duration < 3) {
					this.voiceError = `录音 ${duration.toFixed(1)} 秒太短了 — 至少录满整句话(约 5~8 秒)`;
				} else {
					this.voiceError = '';
				}
				this.voiceState = 'recorded';
			},

			async registerVoice() {
				if (!this.canRegisterVoice || !this.voiceFile) return;
				this.voiceState = 'registering';
				this.voiceError = '';
				const up = await uploadVoiceSample(this.voiceFile, this.voiceFile.name);
				if (!up.ok) {
					this.voiceState = 'error';
					this.voiceError = `上传失败: ${up.error}`;
					return;
				}
				const cl = await cloneVoice({ fileId: up.fileId });
				if (!cl.ok) {
					this.voiceState = 'error';
					this.voiceError = `复刻失败: ${cl.error}`;
					return;
				}
				this.voiceId = cl.voiceId;
				const sampleBlob = base64ToBlob(cl.sampleAudioB64, cl.sampleAudioMime);
				this.voiceSampleUrl = URL.createObjectURL(sampleBlob);
				this.voiceState = 'previewing';
			},

			async confirmVoice() {
				if (this.voiceState !== 'previewing' || !this.voiceFile) return;
				if (!this.artistSlug || !this.artistName.trim()) {
					this.voiceError = '请先在「你是谁」填好显示名,系统才能把声音绑到你的页面';
					this.voiceState = 'recorded';
					return;
				}
				try {
					// 1) 上传音色样本到 audio bucket
					const ext = (this.voiceFile.name.split('.').pop() || 'wav')
						.toLowerCase()
						.replace(/[^a-z0-9]/g, '');
					const samplePath = await uploadVoiceSampleToBucket(
						this.artistSlug,
						this.voiceFile,
						ext,
					);
					this.voiceSamplePath = samplePath;
					// 2) 确保 artists 行存在
					await upsertArtist({
						slug: this.artistSlug,
						name: this.artistName.trim(),
						contact: this.artistContact.trim(),
					});
					// 3) 写 voice_id + sample_path + consent_at
					await setArtistVoice({
						slug: this.artistSlug,
						voiceId: this.voiceId,
						voiceSamplePath: samplePath,
						consentedAt: new Date().toISOString(),
					});
					// 4) 本机缓存,刷新页面也能复用
					try {
						const VOICES_KEY = 'pf:voices:v1';
						const all = JSON.parse(localStorage.getItem(VOICES_KEY) || '{}');
						all[this.artistSlug] = {
							voiceId: this.voiceId,
							voiceSamplePath: samplePath,
							consentAt: new Date().toISOString(),
						};
						localStorage.setItem(VOICES_KEY, JSON.stringify(all));
					} catch {}
					this.voiceState = 'done';
				} catch (e: any) {
					this.voiceState = 'error';
					this.voiceError = `保存失败: ${e?.message || String(e)}`;
				}
			},

			resetVoice() {
				if (this.voiceFileUrl) URL.revokeObjectURL(this.voiceFileUrl);
				if (this.voiceSampleUrl) URL.revokeObjectURL(this.voiceSampleUrl);
				if (this.recording) this.stopRecording();
				this.voiceFile = null;
				this.voiceFileUrl = '';
				this.voiceFileDuration = '';
				this.voiceConsent = false;
				this.voiceId = '';
				this.voiceSamplePath = '';
				this.voiceSampleUrl = '';
				this.voiceError = '';
				this.recordSecs = 0;
				this.voiceState = 'idle';
			},

			/** 根据当前 slug 从 localStorage 还原已登记的音色 */
			restoreVoiceForCurrentSlug() {
				if (!this.artistSlug) return;
				try {
					const all = JSON.parse(localStorage.getItem('pf:voices:v1') || '{}');
					const rec = all[this.artistSlug];
					if (rec && rec.voiceId) {
						this.voiceId = rec.voiceId;
						this.voiceSamplePath = rec.voiceSamplePath || '';
						this.voiceState = 'done';
					}
				} catch {}
			},

			/** 发布完一张图后,生成解说词 + 合成 mp3 + 写回行(灵魂功能 D4)。
			 *  失败不抛错,只在 item.error 上挂提示 —— 解说是锦上添花,
			 *  不能因为它失败就让用户的上传白干。 */
			async generateAndAttachNarration(item: FileItem, photoId: string) {
				item.status = 'narrating';
				try {
					const ctx = {
						title: item.title,
						description: item.description,
						tags: item.ai.suggestion?.tags,
						curatorNote: item.ai.suggestion?.curatorNote,
					};
					const nr = await generateNarrationText(item.file, ctx);
					if (!nr.ok) {
						item.error = `解说词失败: ${nr.error}(图片仍发布成功)`;
						return;
					}
					const sr = await synthesizeSpeech({
						voiceId: this.voiceId,
						text: nr.text,
						style: 'narration',
					});
					if (!sr.ok) {
						item.error = `语音合成失败: ${sr.error}(图片仍发布成功)`;
						return;
					}
					const path = await uploadNarrationMp3(sr.audio, this.artistSlug, photoId);
					await setNarration(photoId, nr.text, path);
					item.narrationText = nr.text;
					item.narrationPath = path;
				} catch (e: any) {
					item.error = `解说生成异常: ${e?.message || String(e)}(图片仍发布成功)`;
				}
			},
			analyzeAllPending() {
				if (!this.aiOn) return;
				for (const f of this.files) {
					if (f.status === 'idle' && (f.ai.status === 'hidden' || f.ai.status === 'error')) {
						this.analyzeOne(f);
					}
				}
			},

			async analyzeOne(f: FileItem) {
				if (!this.aiOn) {
					f.ai.status = 'hidden';
					return;
				}
				f.ai.status = 'loading';
				f.ai.error = '';
				const r = await analyzePhoto(f.file);
				if (!r.ok) {
					f.ai.status = 'error';
					f.ai.error = r.error;
					return;
				}
				f.ai.suggestion = r.suggestion;
				f.ai.reasoning = r.reasoning;
				f.moderation = r.moderation;
				f.chat.history = r.history;
				f.chat.msgs = r.reply ? [{ role: 'assistant', text: r.reply }] : [];
				f.ai.status = 'done';
				// 仅在用户尚未手动改过时，用 AI 建议填充
				if (!f.titleEdited && r.suggestion.title) f.title = r.suggestion.title;
				if (!f.descEdited && r.suggestion.description) f.description = r.suggestion.description;
				// 英文字段:只要 AI 给了就直接填,不做 titleEdited 那套(英文没单独的编辑追踪)
				if (r.suggestion.titleEn) f.titleEn = r.suggestion.titleEn;
				if (r.suggestion.descriptionEn) f.descriptionEn = r.suggestion.descriptionEn;
			},

			async sendChat(f: FileItem) {
				const text = f.chat.input.trim();
				if (!text || f.chat.busy) return;
				f.chat.msgs.push({ role: 'user', text });
				f.chat.input = '';
				f.chat.busy = true;

				// 以表单当前实际值为准，让模型在艺术家手改后的版本上调整
				const cur: AiSuggestion = {
					title: f.title,
					titleEn: f.ai.suggestion?.titleEn || '',
					description: f.description,
					descriptionEn: f.ai.suggestion?.descriptionEn || '',
					curatorNote: f.ai.suggestion?.curatorNote || '',
					tags: f.ai.suggestion?.tags || {
						theme: '',
						style: '',
						medium: '',
						palette: '',
						mood: '',
					},
				};

				const r = await chatRevise(f.chat.history, text, cur);
				f.chat.busy = false;
				if (!r.ok) {
					f.chat.msgs.push({ role: 'assistant', text: '⚠️ ' + r.error });
					return;
				}
				f.chat.history = r.history;
				f.ai.suggestion = r.suggestion;
				if (r.reasoning) f.ai.reasoning = r.reasoning;
				if (r.moderation) f.moderation = r.moderation;
				// 对话是明确的修改意图 → 直接应用到表单，并标记为已编辑防止被覆盖
				if (r.suggestion.title) {
					f.title = r.suggestion.title;
					f.titleEdited = true;
				}
				if (r.suggestion.titleEn) f.titleEn = r.suggestion.titleEn;
				if (r.suggestion.description) {
					f.description = r.suggestion.description;
					f.descEdited = true;
				}
				if (r.suggestion.descriptionEn) f.descriptionEn = r.suggestion.descriptionEn;
				f.chat.msgs.push({ role: 'assistant', text: r.reply });
			},

			tagList(s: AiSuggestion | null) {
				if (!s) return [];
				const t = s.tags;
				return [
					{ k: 'theme', v: t.theme },
					{ k: 'style', v: t.style },
					{ k: 'medium', v: t.medium },
					{ k: 'palette', v: t.palette },
					{ k: 'mood', v: t.mood },
				].filter((x) => x.v);
			},

			removeFile(idx: number) {
				const f = this.files[idx];
				if (f.preview) URL.revokeObjectURL(f.preview);
				this.files.splice(idx, 1);
			},

			async startUpload() {
				if (!this.canUpload) return;
				this.uploading = true;

				localStorage.setItem(
					STORAGE_KEY,
					JSON.stringify({
						artistName: this.artistName,
						artistSlug: this.artistSlug,
						artistContact: this.artistContact,
					}),
				);
				localStorage.setItem(
					COLL_KEY,
					JSON.stringify({ name: this.collectionName, slug: this.collectionSlug }),
				);

				for (const item of this.files) {
					if (item.status !== 'idle') continue;
					// 内容审核未通过的不发布
					if (this.aiOn && item.moderation && item.moderation.safe === false) continue;
					const meta: PhotoMeta = {
						artistName: this.artistName.trim(),
						collectionName: this.collectionName.trim(),
						title: item.title.trim(),
						titleEn: item.titleEn.trim() || undefined,
						description: item.description.trim(),
						descriptionEn: item.descriptionEn.trim() || undefined,
					};
					const contact = this.artistContact.trim();
					try {
						item.status = 'uploading';
						item.progress = 0;
						let photoId = '';
						if (this.mode === 'mock') {
							photoId = await mockUploadOne(item, {
								artistSlug: this.artistSlug,
								collectionSlug: this.collectionSlug,
								meta,
							});
						} else {
							const { width, height } = await readImageMeta(item.file);
							const entry = await uploadPhoto(item.file, {
								artistSlug: this.artistSlug,
								collectionSlug: this.collectionSlug,
								meta,
								contact,
								width,
								height,
								onProgress: (p) => {
									item.progress = p;
								},
							});
							photoId = entry.id;
						}
						// 灵魂功能：发布完图后,如果艺术家已登记声音,生成 AI 解说 mp3
						if (this.voiceId && photoId) {
							await this.generateAndAttachNarration(item, photoId);
						}
						item.status = 'done';
						item.progress = 100;
					} catch (err: any) {
						item.status = 'error';
						item.error = err?.message || '上传失败';
					}
				}
				this.uploading = false;
			},
		};
	}

	function stripExt(name: string) {
		return name.replace(/\.[^.]+$/, '').slice(0, 50) || 'untitled';
	}

	function readImageMeta(
		file: File,
	): Promise<{ width: number; height: number; dataUrl: string }> {
		return new Promise((resolve, reject) => {
			const r = new FileReader();
			r.onerror = () => reject(new Error('无法读取文件'));
			r.onload = () => {
				const dataUrl = r.result as string;
				const img = new Image();
				img.onerror = () => reject(new Error('无法解析图片'));
				img.onload = () => resolve({ width: img.naturalWidth, height: img.naturalHeight, dataUrl });
				img.src = dataUrl;
			};
			r.readAsDataURL(file);
		});
	}

	async function mockUploadOne(
		item: FileItem,
		opts: { artistSlug: string; collectionSlug: string; meta: PhotoMeta },
	): Promise<string> {
		const { width, height, dataUrl } = await readImageMeta(item.file);

		// 模拟上传进度
		await new Promise<void>((resolve) => {
			let p = 0;
			const tick = () => {
				p = Math.min(100, p + 8 + Math.random() * 18);
				item.progress = Math.round(p);
				if (p >= 100) resolve();
				else setTimeout(tick, 80 + Math.random() * 140);
			};
			tick();
		});

		const id = `mock-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
		const entry: PhotoEntry = {
			id,
			width,
			height,
			format: item.file.type.split('/')[1] || 'jpg',
			createdAt: new Date().toISOString(),
			artistSlug: opts.artistSlug,
			collectionSlug: opts.collectionSlug,
			storagePath: '',
			meta: opts.meta,
			...(item.file.size <= MOCK_DATA_URL_LIMIT
				? { dataUrl }
				: { mockSeed: `${opts.artistSlug}-${Math.random().toString(36).slice(2, 8)}` }),
		};
		saveMockUpload(entry);
		return id;
	}

	(window as any).uploadApp = uploadApp;
	document.addEventListener('alpine:init', () => {
		(window as any).Alpine?.data('uploadApp', uploadApp);
	});
</script>
