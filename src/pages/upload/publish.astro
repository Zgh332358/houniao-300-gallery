---
import WizardLayout from '../../layouts/WizardLayout.astro';
---

<WizardLayout
	step="publish"
	title="发布"
	subtitle="检查无误后点「发布」。系统会一张张把图传到 Supabase Storage 并写入元数据。"
>
	<div x-data="publishPage()" x-init="init()" class="space-y-6">
		<!-- 汇总 -->
		<section class="border border-gray-200 rounded-lg p-6 bg-white space-y-3">
			<h2 class="font-semibold">就要发布的内容</h2>
			<dl class="text-sm space-y-1.5">
				<div class="flex justify-between">
					<dt class="text-gray-500">艺术家</dt>
					<dd class="font-medium" x-text="artistName"></dd>
				</div>
				<div class="flex justify-between">
					<dt class="text-gray-500">页面</dt>
					<dd>
						<code class="px-1.5 py-0.5 bg-gray-100 rounded text-gray-700 font-mono text-xs" x-text="`/${artistSlug}/`"></code>
					</dd>
				</div>
				<div class="flex justify-between">
					<dt class="text-gray-500">作品集</dt>
					<dd class="font-medium" x-text="collectionName"></dd>
				</div>
				<div class="flex justify-between">
					<dt class="text-gray-500">作品数</dt>
					<dd class="font-medium" x-text="`${photos.length} 张`"></dd>
				</div>
			</dl>
		</section>

		<!-- 缩略图墙 -->
		<section class="grid grid-cols-3 sm:grid-cols-4 gap-2" x-show="photos.length > 0">
			<template x-for="p in photos" :key="p.id">
				<div class="relative aspect-square overflow-hidden rounded">
					<img :src="p.previewUrl" class="w-full h-full object-cover" />
					<div
						class="absolute inset-0 flex items-center justify-center text-white text-xs font-medium text-center px-1"
						:class="p.publishStatus === 'pending' ? 'bg-black/40' : (p.publishStatus === 'uploading' ? 'bg-violet-600/70' : (p.publishStatus === 'done' ? 'bg-green-600/60' : (p.publishStatus === 'error' ? 'bg-red-600/70' : 'bg-transparent')))"
						x-show="p.publishStatus !== 'idle'"
					>
						<span x-show="p.publishStatus === 'pending'">排队</span>
						<span x-show="p.publishStatus === 'uploading'" x-text="`传 ${p.uploadPct}%`"></span>
						<span x-show="p.publishStatus === 'done'">✓ 已发布</span>
						<span x-show="p.publishStatus === 'error'">! 失败</span>
					</div>
				</div>
			</template>
		</section>

		<!-- 失败明细列表(发布完才显示) -->
		<section
			x-show="!publishing && photos.some((p) => p.publishStatus === 'error')"
			class="border border-amber-200 bg-amber-50 rounded-lg p-4 space-y-2 text-sm"
		>
			<p class="font-semibold text-amber-900">⚠️ 部分图片发布失败:</p>
			<ul class="space-y-1 text-amber-900">
				<template x-for="p in photos.filter((x) => x.publishStatus === 'error')" :key="p.id">
					<li class="flex gap-2">
						<img :src="p.previewUrl" class="w-10 h-10 object-cover rounded flex-shrink-0" />
						<span class="text-xs leading-relaxed">
							<strong x-text="p.title || p.filename"></strong>:
							<span x-text="p.publishError || '未知错误'"></span>
						</span>
					</li>
				</template>
			</ul>
		</section>

		<!-- 发布按钮 + 进度 -->
		<section class="border border-gray-200 rounded-lg p-6 bg-white space-y-4">
			<div class="flex items-center justify-between flex-wrap gap-3">
				<button
					type="button"
					@click="startPublish()"
					:disabled="publishing || allDone"
					class="px-6 py-3 bg-black text-white rounded font-medium hover:bg-violet-600 disabled:bg-gray-300 disabled:cursor-not-allowed flex items-center gap-2"
				>
					<span x-show="!publishing && !allDone">▶ 开始发布</span>
					<span x-show="publishing">发布中...</span>
					<span x-show="allDone">✓ 已全部发布</span>
				</button>
				<p class="text-xs text-gray-500" x-show="publishing">
					本步会把每张图上传到 Supabase Storage 并写入元数据
				</p>
			</div>

			<p x-show="globalError" class="text-sm text-red-600" x-text="globalError"></p>

			<!-- 完成后的分享卡片 -->
			<div
				x-show="allDone"
				class="p-4 bg-violet-50 border border-violet-200 rounded-lg space-y-3"
			>
				<p class="text-sm text-violet-900">
					🎉 你的作品页就在这里 ——
				</p>
				<div class="flex items-center gap-2">
					<input
						type="text"
						readonly
						:value="artistFullUrl"
						@click="$event.target.select()"
						class="flex-1 px-3 py-2 bg-white border border-violet-200 rounded font-mono text-xs text-gray-700 select-all"
					/>
					<button
						type="button"
						@click="copyArtistUrl()"
						class="px-3 py-2 bg-violet-600 text-white rounded text-xs font-medium hover:bg-violet-700 whitespace-nowrap"
						x-text="copied ? '✓ 已复制' : '复制链接'"
					></button>
				</div>
				<div class="flex flex-wrap gap-2 pt-2">
					<a
						:href="artistHref"
						target="_blank"
						class="px-4 py-2 text-sm bg-black text-white rounded hover:bg-violet-600"
					>打开我的页面 →</a>
					<button
						type="button"
						@click="goAddMore()"
						class="px-4 py-2 text-sm border border-gray-300 rounded hover:bg-gray-50"
					>再传一组(回到选图)</button>
				</div>
				<p class="text-xs text-violet-700 pt-1">
					把链接发给朋友、放小红书简介 — 任何人打开都能浏览你的作品。
				</p>
			</div>
		</section>
	</div>

	<script>
		import { uploadPhoto } from '../../lib/photos';
		import {
			getIdentity,
			getCollection,
			listPhotos,
			removePhoto,
			clearAllPhotos,
			gateForStep,
			gateForLogin,
			stepHref,
			type WizardPhoto,
		} from '../../lib/wizard';
		import { requireSession, phoneHash } from '../../lib/auth';

		interface PhotoView extends WizardPhoto {
			previewUrl: string;
			publishStatus: 'idle' | 'pending' | 'uploading' | 'done' | 'error';
			uploadPct: number;
			publishError: string;
		}

		function publishPage() {
			return {
				artistName: '',
				artistSlug: '',
				artistContact: '',
				collectionName: '',
				collectionSlug: '',
				ownerHash: '', // 完整 64 字符 hash,publishOne 时写入 photos.owner_hash
				photos: [] as PhotoView[],
				publishing: false,
				globalError: '',
				copied: false,
				base: '/',

				get allDone(): boolean {
					return this.photos.length > 0 && this.photos.every((p) => p.publishStatus === 'done');
				},
				get artistHref(): string {
					return `${this.base}/${this.artistSlug}/`;
				},
				get artistFullUrl(): string {
					if (typeof location === 'undefined' || !this.artistSlug) return '';
					return `${location.origin}${this.base}/${this.artistSlug}/`;
				},

				async init() {
					const base = (document.documentElement.dataset.base || '/').replace(/\/+$/, '');
					const loginUrl = gateForLogin(base);
					if (loginUrl) {
						location.replace(loginUrl);
						return;
					}
					const gate = await gateForStep('publish');
					if (gate && gate !== 'publish') {
						location.replace(stepHref(base, gate));
						return;
					}
					this.base = base;
					const id = getIdentity();
					this.artistName = id.artistName;
					this.artistSlug = id.artistSlug;
					this.artistContact = id.artistContact;
					const c = getCollection();
					this.collectionName = c.name;
					this.collectionSlug = c.slug;

					const list = await listPhotos();
					this.photos = list.map((p) => ({
						...p,
						previewUrl: URL.createObjectURL(p.blob),
						publishStatus: 'idle' as const,
						uploadPct: 0,
						publishError: '',
					}));

					// 最后一步通常底部 next 按钮没意义,disable 它
					window.__wizardSetNextEnabled?.(false);
				},

				async startPublish() {
					if (this.publishing) return;
					// 守门:必须登录,且 wizard 状态里的 artistSlug 必须等于会话绑定的
					// slug,且我们要算出完整 phoneHash 写进 photos.owner_hash
					try {
						const auth = requireSession();
						if (!auth.slug) {
							this.globalError = '没绑定画廊地址 —— 回身份步先创建画廊';
							return;
						}
						if (this.artistSlug !== auth.slug) {
							this.globalError = `当前会话绑定的是 /${auth.slug}/,但本地 identity 是 /${this.artistSlug}/ —— 不一致,拒绝发布。回身份步检查。`;
							return;
						}
						this.ownerHash = await phoneHash(auth.phone);
					} catch (e: any) {
						this.globalError = e?.message || '需要先登录';
						return;
					}
					this.publishing = true;
					this.globalError = '';
					for (const p of this.photos) p.publishStatus = 'pending';

					for (const p of this.photos) {
						try {
							await this.publishOne(p);
						} catch (e: any) {
							p.publishStatus = 'error';
							p.publishError = e?.message || String(e);
						}
					}
					this.publishing = false;

					// 全发完了:清掉 IDB 里的图,但 identity 保留
					if (this.allDone) {
						await clearAllPhotos();
					}
				},

				async publishOne(p: PhotoView) {
					p.publishStatus = 'uploading';
					p.uploadPct = 0;
					const file = new File([p.blob], p.filename, { type: p.mimeType });
					await uploadPhoto(file, {
						artistSlug: this.artistSlug,
						collectionSlug: this.collectionSlug,
						meta: {
							artistName: this.artistName,
							collectionName: this.collectionName,
							title: p.title,
							titleEn: p.titleEn || undefined,
							description: p.description,
							descriptionEn: p.descriptionEn || undefined,
						},
						contact: this.artistContact,
						ownerHash: this.ownerHash,
						width: p.width,
						height: p.height,
						onProgress: (pct) => {
							p.uploadPct = pct;
						},
					});
					p.uploadPct = 100;
					p.publishStatus = 'done';
					await removePhoto(p.id);
				},

				async copyArtistUrl() {
					if (!this.artistFullUrl) return;
					try {
						await navigator.clipboard.writeText(this.artistFullUrl);
						this.copied = true;
						setTimeout(() => {
							this.copied = false;
						}, 1800);
					} catch {}
				},

				goAddMore() {
					location.href = stepHref(this.base, 'photos');
				},
			};
		}
		(window as any).publishPage = publishPage;
		document.addEventListener('alpine:init', () => {
			(window as any).Alpine?.data('publishPage', publishPage);
		});
	</script>
</WizardLayout>
