---
import WizardLayout from '../../layouts/WizardLayout.astro';

/**
 * 唯一一份提示词文本 —— 同时:
 *   1. 显示给用户朗读
 *   2. 作为 text 参数传给 /v1/audio/voices,让 StepFun 的 ASR 校验通过
 * 两边不一致 → API 抛 CER_NOT_PASS,前面就栽过一次
 */
const VOICE_PROMPT = '如果你听到我的声音,说明你正在看我的作品。慢慢看,慢慢听。';
---

<WizardLayout
	step="voice"
	title="你的声音"
	subtitle="对着麦克风朗读下面这句话,Step 的 stepaudio-2.5-tts 模型会用它克隆你的音色 — 之后每张作品都会用你的声音自动讲解。这一步必填。"
>
	<div x-data="voicePage()" x-init="init()" class="space-y-6" data-voice-prompt={VOICE_PROMPT}>
		<!-- 提示词 -->
		<section
			class="p-5 bg-gray-50 border-l-4 border-violet-400 rounded-r"
			x-show="voiceState !== 'done'"
		>
			<p class="text-xs text-gray-500 mb-2">请朗读 ↓</p>
			<p class="text-lg md:text-xl leading-relaxed text-gray-800">
				「<span x-text="prompt"></span>」
			</p>
			<p class="text-xs text-gray-400 mt-3">约 6~8 秒 · 自然语速 · 不要刻意</p>
		</section>

		<!-- A: 录音 -->
		<section
			class="border border-gray-200 rounded-lg p-6 bg-white space-y-4"
			x-show="voiceState === 'idle' || voiceState === 'recorded' || voiceState === 'error'"
		>
			<div class="flex items-center gap-3 flex-wrap">
				<button
					type="button"
					x-show="!recording"
					@click="startRecording()"
					class="px-5 py-3 rounded-full bg-violet-600 text-white font-medium hover:bg-violet-700 flex items-center gap-2"
				>
					<span class="w-2.5 h-2.5 bg-white rounded-full"></span>
					<span x-text="voiceFile ? '重新录' : '开始录音'"></span>
				</button>
				<button
					type="button"
					x-show="recording"
					@click="stopRecording()"
					class="px-5 py-3 rounded-full bg-red-600 text-white font-medium hover:bg-red-700 flex items-center gap-2"
				>
					<span class="w-2.5 h-2.5 bg-white rounded-sm animate-pulse"></span>
					停止 (<span x-text="recordSecs.toFixed(1)"></span>s)
				</button>
				<span x-show="recording" class="text-xs text-gray-500">
					12 秒后自动停 · 念完按停止最自然
				</span>
			</div>

			<div x-show="voiceFileUrl && !recording" class="space-y-2">
				<audio :src="voiceFileUrl" controls class="w-full"></audio>
				<p class="text-xs text-gray-500">
					录到 <span x-text="voiceFileDuration"></span> · 听一下满意吗?不满意点上面「重新录」
				</p>
			</div>

			<label
				x-show="voiceFile && !recording"
				class="flex items-start gap-2 text-sm text-gray-700 select-none cursor-pointer"
			>
				<input type="checkbox" x-model="voiceConsent" class="mt-1" />
				<span>
					我授权该平台使用这段录音克隆<strong>我本人</strong>的声音,仅用于本平台为我的作品生成 AI 解说语音。
				</span>
			</label>

			<button
				type="button"
				x-show="voiceFile && !recording"
				:disabled="!canRegisterVoice"
				@click="registerVoice()"
				class="px-4 py-2 bg-violet-600 text-white rounded text-sm font-medium hover:bg-violet-700 disabled:bg-gray-300 disabled:cursor-not-allowed"
			>登记我的音色</button>

			<p x-show="voiceError" class="text-sm text-red-600" x-text="voiceError"></p>
		</section>

		<!-- B: 复刻中 -->
		<section
			x-show="voiceState === 'registering'"
			class="border border-violet-200 rounded-lg p-6 bg-violet-50/40 text-violet-800"
		>
			<div class="flex items-center gap-2">
				<svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
					<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="60" stroke-dashoffset="40"></circle>
				</svg>
				<span class="font-medium">正在让 stepaudio-2.5-tts 复刻你的音色...</span>
			</div>
			<p class="text-xs text-violet-700 mt-2 ml-7">通常 5~15 秒。</p>
		</section>

		<!-- C: 试听确认 -->
		<section
			x-show="voiceState === 'previewing'"
			class="border border-violet-200 rounded-lg p-6 bg-violet-50/40 space-y-3"
		>
			<p class="font-medium">已生成你的克隆音色试听 ——</p>
			<audio :src="voiceSampleUrl" controls class="w-full"></audio>
			<p class="text-xs text-gray-600">听一下像不像你?不像就重录,像就「就用它」。</p>
			<div class="flex gap-2">
				<button
					type="button"
					@click="confirmVoice()"
					class="px-5 py-2.5 bg-violet-600 text-white rounded font-medium hover:bg-violet-700"
				>✓ 就用它</button>
				<button
					type="button"
					@click="resetVoice()"
					class="px-5 py-2.5 border border-gray-300 rounded text-sm hover:bg-gray-50"
				>重录</button>
			</div>
		</section>

		<!-- D: 已登记 -->
		<section
			x-show="voiceState === 'done'"
			class="border border-violet-200 rounded-lg p-6 bg-violet-50/40 space-y-2"
		>
			<p class="text-violet-800 font-medium">
				✅ 已登记你的克隆音色,绑定到 <code class="bg-white px-1.5 py-0.5 rounded font-mono text-xs" x-text="`/${artistSlug}/`"></code>
			</p>
			<p class="text-xs text-gray-500 font-mono break-all">voice_id: <span x-text="voiceId"></span></p>
			<button
				type="button"
				@click="resetVoice()"
				class="text-xs text-gray-500 underline hover:text-gray-800"
			>换一段录音重做</button>
		</section>
	</div>

	<script>
		import {
			uploadVoiceSample as uploadStepFile,
			cloneVoice,
			base64ToBlob,
		} from '../../lib/ai-voice';
		import {
			upsertArtist,
			setArtistVoice,
			uploadVoiceSample as uploadVoiceSampleToBucket,
		} from '../../lib/artists';
		import { blobToWav, pickRecorderMime } from '../../lib/wav';
		import {
			getIdentity,
			getVoiceForSlug,
			saveVoiceForSlug,
			gateForStep,
			stepHref,
		} from '../../lib/wizard';

		function voicePage() {
			return {
				prompt: '',
				artistSlug: '',
				artistName: '',
				artistContact: '',
				voiceState: 'idle' as
					| 'idle'
					| 'recorded'
					| 'registering'
					| 'previewing'
					| 'done'
					| 'error',
				voiceFile: null as File | null,
				voiceFileUrl: '',
				voiceFileDuration: '',
				voiceConsent: false,
				voiceId: '',
				voiceSamplePath: '',
				voiceSampleUrl: '',
				voiceError: '',
				recording: false,
				recordSecs: 0,
				_mediaRecorder: null as MediaRecorder | null,
				_mediaStream: null as MediaStream | null,
				_recordChunks: [] as Blob[],
				_recordTimer: 0,
				_recordStartedAt: 0,

				get canRegisterVoice(): boolean {
					return (
						this.voiceState !== 'registering' &&
						this.voiceState !== 'previewing' &&
						this.voiceState !== 'done' &&
						!!this.voiceFile &&
						this.voiceConsent
					);
				},

				async init() {
					const gate = await gateForStep('voice');
					if (gate && gate !== 'voice') {
						const base = (document.documentElement.dataset.base || '/') as string;
						location.replace(stepHref(base, gate));
						return;
					}
					// 从 DOM dataset 读那份唯一提示词,跟传给 API 的字符串保持一致
					this.prompt = this.$root?.dataset?.voicePrompt || '';
					const id = getIdentity();
					this.artistSlug = id.artistSlug;
					this.artistName = id.artistName;
					this.artistContact = id.artistContact;
					const v = getVoiceForSlug(this.artistSlug);
					if (v) {
						this.voiceId = v.voiceId;
						this.voiceSamplePath = v.voiceSamplePath;
						this.voiceState = 'done';
					}
					this.syncNext();
					this.$watch('voiceState', () => this.syncNext());
				},

				syncNext() {
					window.__wizardSetNextEnabled?.(this.voiceState === 'done');
				},

				async startRecording() {
					this.voiceError = '';
					if (!navigator.mediaDevices?.getUserMedia) {
						this.voiceError = '当前浏览器不支持录音,请用 Chrome / Edge / Safari';
						return;
					}
					let stream: MediaStream;
					try {
						stream = await navigator.mediaDevices.getUserMedia({ audio: true });
					} catch (err: any) {
						this.voiceError =
							err?.name === 'NotAllowedError'
								? '麦克风权限被拒绝。在浏览器地址栏左侧重新允许。'
								: `麦克风启动失败: ${err?.message || String(err)}`;
						return;
					}
					const mime = pickRecorderMime();
					let mr: MediaRecorder;
					try {
						mr = mime ? new MediaRecorder(stream, { mimeType: mime }) : new MediaRecorder(stream);
					} catch (err: any) {
						this.voiceError = `MediaRecorder 启动失败: ${err?.message || String(err)}`;
						stream.getTracks().forEach((t) => t.stop());
						return;
					}

					if (this.voiceFileUrl) {
						URL.revokeObjectURL(this.voiceFileUrl);
						this.voiceFileUrl = '';
					}
					this.voiceFile = null;
					this._recordChunks = [];

					mr.addEventListener('dataavailable', (e: BlobEvent) => {
						if (e.data && e.data.size > 0) this._recordChunks.push(e.data);
					});
					mr.addEventListener('stop', () => {
						this._finalizeRecording();
					});

					this._mediaRecorder = mr;
					this._mediaStream = stream;
					this._recordStartedAt = performance.now();
					this.recordSecs = 0;
					mr.start();
					this.recording = true;

					const tick = () => {
						if (!this.recording) return;
						this.recordSecs = (performance.now() - this._recordStartedAt) / 1000;
						if (this.recordSecs >= 12) {
							this.stopRecording();
							return;
						}
						this._recordTimer = window.setTimeout(tick, 100);
					};
					tick();
				},

				stopRecording() {
					if (!this.recording) return;
					this.recording = false;
					if (this._recordTimer) {
						clearTimeout(this._recordTimer);
						this._recordTimer = 0;
					}
					try {
						this._mediaRecorder?.stop();
					} catch {}
					try {
						this._mediaStream?.getTracks().forEach((t) => t.stop());
					} catch {}
					this._mediaStream = null;
				},

				async _finalizeRecording() {
					const recorder = this._mediaRecorder;
					this._mediaRecorder = null;
					if (!this._recordChunks.length) {
						this.voiceError = '没录到声音 — 检查麦克风或重试';
						return;
					}
					const recordedMime = recorder?.mimeType || this._recordChunks[0]?.type || 'audio/webm';
					const rawBlob = new Blob(this._recordChunks, { type: recordedMime });
					this._recordChunks = [];
					let wavBlob: Blob;
					try {
						wavBlob = await blobToWav(rawBlob);
					} catch (err: any) {
						this.voiceError = `录音转 WAV 失败: ${err?.message || String(err)}`;
						return;
					}
					if (this.voiceFileUrl) URL.revokeObjectURL(this.voiceFileUrl);
					this.voiceFileUrl = URL.createObjectURL(rawBlob);
					const filename = `${this.artistSlug || 'voice'}-${Date.now()}.wav`;
					this.voiceFile = new File([wavBlob], filename, { type: 'audio/wav' });
					const duration = (performance.now() - this._recordStartedAt) / 1000;
					this.voiceFileDuration = `${duration.toFixed(1)} 秒`;
					if (duration < 3) {
						this.voiceError = `录音 ${duration.toFixed(1)} 秒太短了 — 至少录满整句话(约 5~8 秒)`;
					} else {
						this.voiceError = '';
					}
					this.voiceState = 'recorded';
				},

				async registerVoice() {
					if (!this.canRegisterVoice || !this.voiceFile) return;
					this.voiceState = 'registering';
					this.voiceError = '';
					const up = await uploadStepFile(this.voiceFile, this.voiceFile.name);
					if (!up.ok) {
						this.voiceState = 'error';
						this.voiceError = `上传失败: ${up.error}`;
						return;
					}
					const cl = await cloneVoice({
						fileId: up.fileId,
						// 关键: 必须把用户朗读的提示词传过去 ——
						// StepFun 服务端对录音跑 ASR,用 text 字段做 CER 校验,
						// 两者不匹配会直接拒(CER_NOT_PASS)
						text: this.prompt,
						sampleText: this.prompt,
					});
					if (!cl.ok) {
						this.voiceState = 'error';
						this.voiceError = `复刻失败: ${cl.error}`;
						return;
					}
					this.voiceId = cl.voiceId;
					const sampleBlob = base64ToBlob(cl.sampleAudioB64, cl.sampleAudioMime);
					this.voiceSampleUrl = URL.createObjectURL(sampleBlob);
					this.voiceState = 'previewing';
				},

				async confirmVoice() {
					if (this.voiceState !== 'previewing' || !this.voiceFile) return;
					try {
						const ext = (this.voiceFile.name.split('.').pop() || 'wav')
							.toLowerCase()
							.replace(/[^a-z0-9]/g, '');
						const samplePath = await uploadVoiceSampleToBucket(
							this.artistSlug,
							this.voiceFile,
							ext,
						);
						this.voiceSamplePath = samplePath;
						await upsertArtist({
							slug: this.artistSlug,
							name: this.artistName.trim(),
							contact: this.artistContact.trim(),
						});
						const consentedAt = new Date().toISOString();
						await setArtistVoice({
							slug: this.artistSlug,
							voiceId: this.voiceId,
							voiceSamplePath: samplePath,
							consentedAt,
						});
						saveVoiceForSlug(this.artistSlug, {
							voiceId: this.voiceId,
							voiceSamplePath: samplePath,
							consentAt: consentedAt,
						});
						this.voiceState = 'done';
					} catch (e: any) {
						this.voiceState = 'error';
						this.voiceError = `保存失败: ${e?.message || String(e)}`;
					}
				},

				resetVoice() {
					if (this.voiceFileUrl) URL.revokeObjectURL(this.voiceFileUrl);
					if (this.voiceSampleUrl) URL.revokeObjectURL(this.voiceSampleUrl);
					if (this.recording) this.stopRecording();
					this.voiceFile = null;
					this.voiceFileUrl = '';
					this.voiceFileDuration = '';
					this.voiceConsent = false;
					this.voiceId = '';
					this.voiceSamplePath = '';
					this.voiceSampleUrl = '';
					this.voiceError = '';
					this.recordSecs = 0;
					this.voiceState = 'idle';
				},
			};
		}
		(window as any).voicePage = voicePage;
		document.addEventListener('alpine:init', () => {
			(window as any).Alpine?.data('voicePage', voicePage);
		});
	</script>
</WizardLayout>
