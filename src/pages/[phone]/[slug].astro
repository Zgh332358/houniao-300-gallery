---
import MainLayout from '../../layouts/MainLayout.astro';
import 'glightbox/dist/css/glightbox.css';
import '../../styles/glightbox-custom.css';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
	// 占位:phoneHash8 + slug 都未知,由 postbuild 把这个 HTML 复制成
	// dist/404.html。所有 /<phoneHash8>/<slug>/ 和 /<hash8>/<slug>/show/<id>/
	// 路径都 fallback 到这里,由客户端 parseFromUrl 区分 gallery / show 模式。
	return [{ params: { phone: '__phone__', slug: '__slug__' } }];
}
---

<MainLayout>
	<section
		id="artist-page"
		class="pt-32 pb-20"
		x-data="artistPage()"
		x-init="init()"
		data-base={base}
	>
		<div class="container-custom px-4">
			<!-- 加载态 -->
			<template x-if="loading">
				<div class="text-center py-20 text-gray-400">加载中…</div>
			</template>

			<!-- 找不到艺术家 / show -->
			<template x-if="!loading && photos.length === 0 && !currentShow">
				<div class="text-center py-20">
					<h1 class="text-3xl font-bold mb-4" x-text="`没找到「${slug}」`"></h1>
					<p class="text-gray-600 mb-8">
						这个画廊还没有作品,或者地址写错了。<br />
						你可以去 <a :href="`${base}/upload/`" class="underline">上传页</a> 创建你自己的页面。
					</p>
				</div>
			</template>

			<!-- ============ Gallery mode ============ -->
			<template x-if="!loading && !showMode && photos.length > 0">
				<div>
					<!-- 艺术家头部 -->
					<header class="text-center mb-12">
						<h1 class="text-4xl md:text-5xl font-bold mb-3" x-text="artistName"></h1>
						<p class="text-sm text-gray-500 mt-4">
							<span x-text="photos.length"></span> 张作品 ·
							<span x-text="collections.length"></span> 个作品集
						</p>
						<p class="text-xs text-gray-400 mt-2 font-mono">
							<span x-text="phoneHash8"></span> · <span x-text="`/${slug}/`"></span>
						</p>

						<!-- shows chip 列表(owner 和访客都看,如有) -->
						<template x-if="showsList.length > 0">
							<div class="mt-6 flex flex-wrap items-center justify-center gap-2">
								<span class="text-xs text-gray-500">📺 动态展示:</span>
								<template x-for="s in showsList" :key="s.id">
									<a
										:href="`${base}/${phoneHash8}/${slug}/show/${s.id}/`"
										class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-violet-100 text-violet-700 text-xs hover:bg-violet-200 transition-colors"
									>
										<span x-text="layoutEmoji(s.layout)"></span>
										<span x-text="s.title || '未命名'"></span>
										<span class="text-violet-400" x-text="`(${s.photoIds.length})`"></span>
									</a>
								</template>
							</div>
						</template>

						<!-- owner 胶囊 -->
						<template x-if="isOwner">
							<div class="mt-4 inline-flex flex-wrap items-center justify-center gap-3 px-4 py-2 rounded-full bg-violet-50 border border-violet-200">
								<span class="text-xs text-violet-700">这是你自己的画廊</span>
								<span class="text-violet-300">|</span>
								<button
									type="button"
									@click="toggleEditMode()"
									class="flex items-center gap-1.5 text-xs font-medium transition-colors"
									:class="editMode ? 'text-red-600' : 'text-gray-600 hover:text-violet-700'"
								>
									<span
										class="inline-block w-8 h-4 rounded-full transition-colors relative"
										:class="editMode ? 'bg-red-500' : 'bg-gray-300'"
									>
										<span
											class="absolute top-0.5 w-3 h-3 rounded-full bg-white transition-all"
											:class="editMode ? 'left-4' : 'left-0.5'"
										></span>
									</span>
									<span x-text="editMode ? '编辑模式 (点 × 删除)' : '编辑模式'"></span>
								</button>
								<span class="text-violet-300">|</span>
								<button
									type="button"
									@click="openPicker()"
									class="text-xs text-violet-700 hover:underline"
								>+ 创建动态展示</button>
								<span class="text-violet-300">|</span>
								<a
									:href="`${base}/upload/setup/`"
									class="text-xs text-violet-700 hover:underline"
								>+ 上传新作品</a>
							</div>
						</template>
					</header>

					<!-- collection 标签栏 -->
					<div class="flex justify-center mb-10" x-show="collections.length > 1">
						<div class="flex flex-wrap gap-2 justify-center">
							<button
								@click="selectCollection(null)"
								class="px-4 py-2 border transition-all"
								:class="
									activeColl === null
										? 'border-black bg-black text-white'
										: 'border-gray-200 text-gray-700 hover:border-gray-300'
								"
							>
								全部
							</button>
							<template x-for="c in collections" :key="c.slug">
								<button
									@click="selectCollection(c.slug)"
									class="px-4 py-2 border transition-all"
									:class="
										activeColl === c.slug
											? 'border-black bg-black text-white'
											: 'border-gray-200 text-gray-700 hover:border-gray-300'
									"
									x-text="c.name"
								></button>
							</template>
						</div>
					</div>

					<!-- Photo Grid 容器,由 JS 动态填充 -->
					<section
						id="photo-grid"
						class="relative w-full mx-auto overflow-hidden"
					></section>
				</div>
			</template>

			<!-- ============ Show mode ============ -->
			<template x-if="!loading && showMode && currentShow">
				<div class="show-page-wrap">
					<!-- 顶部条 -->
					<div class="show-topbar">
						<a
							:href="`${base}/${phoneHash8}/${slug}/`"
							class="show-back-btn"
							title="回画廊"
						>← 回到画廊</a>
						<div class="show-title-area">
							<div class="show-title" x-text="currentShow.title || '未命名展示'"></div>
							<div class="show-meta">
								<span x-text="layoutLabel(currentShow.layout)"></span>
								<span class="mx-1">·</span>
								<span x-text="`${currentShow.photoIds.length} 张`"></span>
							</div>
						</div>
						<template x-if="isOwner">
							<button
								type="button"
								@click="deleteCurrentShow()"
								class="show-delete-btn"
								title="删除这个展示(不会删图)"
							>× 删除展示</button>
						</template>
					</div>
					<!-- viewer 容器,JS mount Swiper / scroll-snap 进来 -->
					<div id="show-viewer"></div>
				</div>
			</template>
		</div>
	</section>

	<!-- ============ Picker Modal(owner 创建展示用) ============ -->
	<div
		x-cloak
		x-show="pickerOpen"
		x-data="{}"
		class="picker-overlay"
		@click.self="closePicker()"
	>
		<div class="picker-panel" @click.stop>
			<div class="picker-header">
				<h3 class="text-xl font-bold">创建动态展示</h3>
				<button @click="closePicker()" class="picker-close">×</button>
			</div>

			<div class="picker-body">
				<label class="block mb-4">
					<span class="text-sm text-gray-600 block mb-1">标题(可选)</span>
					<input
						type="text"
						x-model="pickerTitle"
						placeholder="例:夜色街拍精选"
						class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:border-black"
					/>
				</label>

				<div class="mb-5">
					<span class="text-sm text-gray-600 block mb-2">展示样式</span>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
						<template x-for="opt in LAYOUT_OPTS" :key="opt.key">
							<button
								type="button"
								@click="pickerLayout = opt.key"
								class="text-left p-3 rounded-lg border-2 transition-colors"
								:class="pickerLayout === opt.key ? 'border-violet-500 bg-violet-50' : 'border-gray-200 hover:border-gray-300'"
							>
								<div class="text-2xl mb-1" x-text="opt.emoji"></div>
								<div class="font-medium text-sm" x-text="opt.name"></div>
								<div class="text-xs text-gray-500 mt-0.5" x-text="opt.hint"></div>
							</button>
						</template>
					</div>
				</div>

				<div>
					<span class="text-sm text-gray-600 block mb-2">
						选图(点击多选 · 序号即播放顺序 · 至少 1 张)
					</span>
					<div class="picker-grid">
						<template x-for="p in photos" :key="p.id">
							<button
								type="button"
								@click="togglePick(p.id)"
								class="picker-tile"
								:class="pickerSelected.includes(p.id) ? 'picked' : ''"
							>
								<img :src="thumbUrl(p)" :alt="p.meta.title || ''" loading="lazy" />
								<template x-if="pickerSelected.includes(p.id)">
									<span class="picker-badge" x-text="pickerSelected.indexOf(p.id) + 1"></span>
								</template>
							</button>
						</template>
					</div>
				</div>
			</div>

			<div class="picker-footer">
				<span class="text-sm text-gray-500">
					已选 <strong x-text="pickerSelected.length"></strong> 张
				</span>
				<div class="flex gap-2">
					<button @click="closePicker()" class="px-4 py-2 text-sm text-gray-600 hover:text-black">取消</button>
					<button
						@click="savePicker()"
						:disabled="!canSavePicker || pickerBusy"
						class="px-5 py-2 bg-black text-white text-sm rounded font-medium hover:bg-violet-600 disabled:bg-gray-300 disabled:cursor-not-allowed"
					>
						<span x-show="!pickerBusy">保存 + 打开</span>
						<span x-show="pickerBusy">保存中...</span>
					</button>
				</div>
			</div>
			<p
				x-show="pickerError"
				x-text="pickerError"
				class="text-xs text-red-600 mt-2 px-5"
			></p>
		</div>
	</div>
</MainLayout>

<script>
	import {
		listAll,
		groupByCollection,
		deliveryUrl,
		srcSet,
		deletePhoto,
		type PhotoEntry,
	} from '../../lib/photos';
	import { setupGallery, teardownGallery } from '../../scripts/photo-grid';
	import { getSession, phoneHash } from '../../lib/auth';
	import {
		listShows,
		getShow,
		createShow,
		deleteShow,
		type Show,
		type ShowLayout,
	} from '../../lib/shows';
	import { renderShow } from '../../scripts/show-viewers';

	const LAYOUT_OPTS: { key: ShowLayout; emoji: string; name: string; hint: string }[] = [
		{ key: 'coverflow', emoji: '🎞️', name: '3D 旋转', hint: '中间正放,两侧后退' },
		{ key: 'cards', emoji: '🃏', name: '堆叠卡片', hint: '左右滑发牌切换' },
		{ key: 'snap', emoji: '📜', name: '全屏垂直', hint: '滚动咔嚓换一张' },
	];
	const LAYOUT_LABEL: Record<ShowLayout, string> = {
		coverflow: '3D 旋转',
		cards: '堆叠卡片',
		snap: '全屏垂直',
	};
	const LAYOUT_EMOJI: Record<ShowLayout, string> = {
		coverflow: '🎞️',
		cards: '🃏',
		snap: '📜',
	};

	function artistPage() {
		return {
			LAYOUT_OPTS,
			loading: true,
			slug: '',
			phoneHash8: '',
			base: '',
			photos: [] as PhotoEntry[],
			collections: [] as { slug: string; name: string }[],
			activeColl: null as string | null,
			artistName: '',
			isOwner: false,
			editMode: false,

			// shows
			showsList: [] as Show[],

			// show mode
			showMode: false,
			currentShow: null as Show | null,

			// picker modal
			pickerOpen: false,
			pickerTitle: '',
			pickerLayout: 'coverflow' as ShowLayout,
			pickerSelected: [] as string[],
			pickerBusy: false,
			pickerError: '',

			get canSavePicker(): boolean {
				return this.pickerSelected.length > 0;
			},

			layoutLabel(k: ShowLayout): string {
				return LAYOUT_LABEL[k] || k;
			},
			layoutEmoji(k: ShowLayout): string {
				return LAYOUT_EMOJI[k] || '📺';
			},
			thumbUrl(p: PhotoEntry): string {
				return deliveryUrl(p, { width: 400 });
			},

			async init() {
				this.base = (document.documentElement.dataset.base || '').replace(/\/+$/, '');
				const parsed = parseFromUrl();
				this.phoneHash8 = parsed.phone8;
				this.slug = parsed.slug;
				if (!this.slug || !this.phoneHash8) {
					this.loading = false;
					return;
				}

				const all = await listAll();
				const mine = all.filter(
					(p) => p.artistSlug === this.slug && p.ownerHash?.startsWith(this.phoneHash8),
				);
				this.photos = mine;

				if (mine.length > 0) {
					this.artistName = mine[0].meta.artistName || this.slug;
					const groups = groupByCollection(mine);
					this.collections = groups.map((g) => ({ slug: g.slug, name: g.name }));

					// owner 判定:完整 hash 比对
					const session = getSession();
					if (session && session.phone && mine[0].ownerHash) {
						try {
							const myFull = await phoneHash(session.phone);
							this.isOwner = myFull === mine[0].ownerHash;
						} catch {
							this.isOwner = false;
						}
					}

					// 拉这个 artist 的 shows(展示列表/show 详情查找两用)
					const fullOwnerHash = mine[0].ownerHash || '';
					this.showsList = await listShows({
						ownerHash: fullOwnerHash,
						artistSlug: this.slug,
					});
				}

				// === 分两路:show mode vs gallery mode ===
				if (parsed.showId) {
					const show = await getShow(parsed.showId);
					if (show && show.artistSlug === this.slug && show.ownerHash.startsWith(this.phoneHash8)) {
						this.currentShow = show;
						this.showMode = true;
						this.loading = false;
						await this.$nextTick();
						const container = document.getElementById('show-viewer');
						if (container) {
							// 按 photoIds 数组顺序过滤 photos
							const idIdx = new Map(show.photoIds.map((id, i) => [id, i]));
							const orderedPhotos = mine
								.filter((p) => idIdx.has(p.id))
								.sort((a, b) => (idIdx.get(a.id) ?? 0) - (idIdx.get(b.id) ?? 0));
							renderShow(container, show.layout, orderedPhotos);
						}
						return;
					}
					// show 找不到 / 不属于这个 artist → 退化到 gallery mode 显示
				}

				this.loading = false;
				await this.$nextTick();
				renderGrid(this.filtered(), this.isOwner && this.editMode, (id, path) => this.removeOne(id, path));
			},

			async removeOne(photoId: string, storagePath: string) {
				if (!this.isOwner || !this.editMode) return;
				if (!confirm('确认删除这张作品?删除后无法恢复。')) return;
				try {
					await deletePhoto(photoId, storagePath);
					this.photos = this.photos.filter((p) => p.id !== photoId);
					if (this.photos.length > 0) {
						const groups = groupByCollection(this.photos);
						this.collections = groups.map((g) => ({ slug: g.slug, name: g.name }));
					} else {
						this.collections = [];
					}
					await this.$nextTick();
					renderGrid(this.filtered(), this.isOwner && this.editMode, (id, path) => this.removeOne(id, path));
				} catch (e: any) {
					alert(e?.message || '删除失败,稍后再试');
				}
			},

			filtered() {
				if (!this.activeColl) return this.photos;
				return this.photos.filter((p) => p.collectionSlug === this.activeColl);
			},

			async selectCollection(coll: string | null) {
				this.activeColl = coll;
				await this.$nextTick();
				renderGrid(this.filtered(), this.isOwner && this.editMode, (id, path) => this.removeOne(id, path));
			},

			async toggleEditMode() {
				if (!this.isOwner) return;
				this.editMode = !this.editMode;
				await this.$nextTick();
				renderGrid(this.filtered(), this.isOwner && this.editMode, (id, path) => this.removeOne(id, path));
			},

			/* ---------- Picker ---------- */
			openPicker() {
				if (!this.isOwner) return;
				this.pickerTitle = '';
				this.pickerLayout = 'coverflow';
				this.pickerSelected = [];
				this.pickerError = '';
				this.pickerOpen = true;
			},
			closePicker() {
				if (this.pickerBusy) return;
				this.pickerOpen = false;
			},
			togglePick(photoId: string) {
				const i = this.pickerSelected.indexOf(photoId);
				if (i >= 0) this.pickerSelected.splice(i, 1);
				else this.pickerSelected.push(photoId);
			},
			async savePicker() {
				if (this.pickerBusy || !this.canSavePicker) return;
				this.pickerError = '';
				const session = getSession();
				if (!session) {
					this.pickerError = '会话失效,回 /login';
					return;
				}
				const ownerHash = this.photos[0]?.ownerHash;
				if (!ownerHash) {
					this.pickerError = '当前画廊没有图,无法创建';
					return;
				}
				this.pickerBusy = true;
				try {
					const id = await createShow({
						ownerHash,
						artistSlug: this.slug,
						title: this.pickerTitle.trim(),
						layout: this.pickerLayout,
						photoIds: this.pickerSelected,
					});
					location.href = `${this.base}/${this.phoneHash8}/${this.slug}/show/${id}/`;
				} catch (e: any) {
					this.pickerError = e?.message || '保存失败';
					this.pickerBusy = false;
				}
			},

			async deleteCurrentShow() {
				if (!this.isOwner || !this.currentShow) return;
				if (!confirm('删除这个展示?(图本身不会被删,只是把这个展示页拆掉)')) return;
				try {
					await deleteShow(this.currentShow.id);
					location.replace(`${this.base}/${this.phoneHash8}/${this.slug}/`);
				} catch (e: any) {
					alert(e?.message || '删除展示失败');
				}
			},
		};
	}

	function parseFromUrl(): { phone8: string; slug: string; showId: string | null } {
		// dev 模式 ?phone=xxx&slug=yyy&show=zzz 走 query
		const params = new URLSearchParams(window.location.search);
		const qPhone = params.get('phone') || '';
		const qSlug = params.get('slug') || '';
		const qShow = params.get('show') || null;
		if (qPhone && qSlug) return { phone8: qPhone, slug: qSlug, showId: qShow };

		// 正常路径:/<base>/<phoneHash8>/<slug>[/show/<showId>]/
		const path = window.location.pathname.replace(/\/+$/, '');
		const baseEl = document.getElementById('artist-page');
		const base = (baseEl?.dataset.base || '/').replace(/\/+$/, '');
		let rest = path;
		if (base && rest.startsWith(base)) rest = rest.slice(base.length);
		rest = rest.replace(/^\/+/, '');
		const segs = rest.split('/').filter(Boolean);
		const phone8 = segs[0] || '';
		const slug = segs[1] || '';
		const showId = segs[2] === 'show' && segs[3] ? segs[3] : null;
		if (phone8 === '__phone__' || slug === '__slug__') return { phone8: '', slug: '', showId: null };
		const reserved = new Set(['', 'about', 'collections', 'upload', 'artists', 'search', 'login']);
		if (reserved.has(phone8)) return { phone8: '', slug: '', showId: null };
		if (!slug) return { phone8: '', slug: '', showId: null };
		if (!/^[0-9a-f]{8}$/i.test(phone8)) return { phone8: '', slug: '', showId: null };
		return { phone8, slug, showId };
	}

	function renderGrid(
		photos: PhotoEntry[],
		isOwner: boolean = false,
		onDelete?: (photoId: string, storagePath: string) => void,
	) {
		const grid = document.getElementById('photo-grid');
		if (!grid) return;
		teardownGallery();
		grid.innerHTML = '';
		grid.removeAttribute('style');
		for (const p of photos) {
			const a = document.createElement('a');
			a.className = 'photo-item glightbox absolute transition-transform hover:scale-[1.02] hover:z-10';
			a.href = deliveryUrl(p, { width: 2000 });
			a.dataset.gallery = 'gallery1';
			a.dataset.type = 'image';
			if (p.meta.description) {
				a.dataset.glightbox = `title: ${p.meta.description}`;
			}

			const img = document.createElement('img');
			img.src = deliveryUrl(p, { width: 800 });
			img.srcset = srcSet(p);
			img.sizes = '(max-width: 768px) 50vw, 33vw';
			img.alt = p.meta.title || '';
			img.width = p.width;
			img.height = p.height;
			img.loading = 'lazy';
			img.className = 'w-full h-full object-cover rounded-sm shadow-sm hover:shadow-lg transition-shadow';
			a.appendChild(img);

			if (p.meta.title) {
				const tag = document.createElement('div');
				tag.className =
					'photo-title-tag absolute bottom-2 right-2 px-2 py-1 rounded-md bg-black/60 text-white text-[11px] font-medium backdrop-blur-sm pointer-events-none max-w-[80%] truncate';
				tag.textContent = p.meta.title;
				a.appendChild(tag);
			}

			if (isOwner && onDelete) {
				const btn = document.createElement('button');
				btn.type = 'button';
				btn.title = '删除这张作品';
				btn.setAttribute('aria-label', '删除作品');
				btn.className =
					'photo-delete-btn absolute top-2 right-2 w-7 h-7 rounded-full bg-red-600/85 hover:bg-red-700 text-white text-base font-bold flex items-center justify-center shadow-md transition';
				btn.textContent = '×';
				btn.addEventListener('click', (e) => {
					e.preventDefault();
					e.stopPropagation();
					onDelete(p.id, p.storagePath);
				});
				a.appendChild(btn);
			}

			grid.appendChild(a);
		}
		setupGallery();
	}

	(window as any).artistPage = artistPage;
	document.addEventListener('alpine:init', () => {
		(window as any).Alpine?.data('artistPage', artistPage);
	});
</script>

