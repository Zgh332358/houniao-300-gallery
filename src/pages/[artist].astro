---
import MainLayout from '../layouts/MainLayout.astro';
import 'glightbox/dist/css/glightbox.css';
import '../styles/glightbox-custom.css';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
	// 占位 slug：构建时无法知道艺术家列表，由 postbuild 把这个 HTML 复制成
	// dist/404.html，所有 /<slug>/ 未知路径都 fallback 到这里，由客户端解析 URL。
	return [{ params: { artist: '__artist__' } }];
}
---

<MainLayout>
	<section
		id="artist-page"
		class="pt-32 pb-20"
		x-data="artistPage()"
		x-init="init()"
		data-base={base}
	>
		<div class="container-custom px-4">
			<!-- 加载态 -->
			<template x-if="loading">
				<div class="text-center py-20 text-gray-400">加载中…</div>
			</template>

			<!-- 找不到艺术家 -->
			<template x-if="!loading && photos.length === 0">
				<div class="text-center py-20">
					<h1 class="text-3xl font-bold mb-4" x-text="`没找到「${slug}」`"></h1>
					<p class="text-gray-600 mb-8">
						这个艺术家页还没有作品，或者 slug 拼写有误。<br />
						你可以去 <a :href="`${base}/upload/`" class="underline">上传页</a> 创建你自己的页面。
					</p>
				</div>
			</template>

			<!-- 正常展示 -->
			<template x-if="!loading && photos.length > 0">
				<div>
					<!-- 艺术家头部 -->
					<header class="text-center mb-12">
						<h1 class="text-4xl md:text-5xl font-bold mb-3" x-text="artistName"></h1>
						<p class="text-sm text-gray-500 mt-4">
							<span x-text="photos.length"></span> 张作品 ·
							<span x-text="collections.length"></span> 个作品集
						</p>

						<!-- 🎙️ 自动语音导览 -->
						<div x-show="narratableCount > 0" class="mt-6 flex flex-col items-center gap-2">
							<button
								@click="toggleTour()"
								class="px-5 py-2.5 rounded-full font-medium transition-colors flex items-center gap-2"
								:class="tourOn ? 'bg-violet-600 text-white hover:bg-violet-700' : 'bg-black text-white hover:bg-violet-600'"
							>
								<span x-show="!tourOn">▶ 自动语音导览</span>
								<span x-show="tourOn">⏸ 停止导览</span>
							</button>
							<p class="text-xs text-gray-400">
								<span x-text="narratableCount"></span> 张作品有 AI 合成语音解说
							</p>
						</div>
					</header>

					<!-- collection 标签栏 -->
					<div class="flex justify-center mb-10" x-show="collections.length > 1">
						<div class="flex flex-wrap gap-2 justify-center">
							<button
								@click="selectCollection(null)"
								class="px-4 py-2 border transition-all"
								:class="
									activeColl === null
										? 'border-black bg-black text-white'
										: 'border-gray-200 text-gray-700 hover:border-gray-300'
								"
							>
								全部
							</button>
							<template x-for="c in collections" :key="c.slug">
								<button
									@click="selectCollection(c.slug)"
									class="px-4 py-2 border transition-all"
									:class="
										activeColl === c.slug
											? 'border-black bg-black text-white'
											: 'border-gray-200 text-gray-700 hover:border-gray-300'
									"
									x-text="c.name"
								>
								</button>
							</template>
						</div>
					</div>

					<!-- Photo Grid 容器，由 JS 动态填充 -->
					<section
						id="photo-grid"
						class="relative w-full mx-auto overflow-hidden"
					>
					</section>
				</div>
			</template>
		</div>
	</section>
</MainLayout>

<script>
	import {
		listAll,
		groupByCollection,
		deliveryUrl,
		srcSet,
		narrationUrl,
		type PhotoEntry,
	} from '../lib/photos';
	import { setupGallery, teardownGallery } from '../scripts/photo-grid';

	function artistPage() {
		return {
			loading: true,
			slug: '',
			photos: [] as PhotoEntry[],
			collections: [] as { slug: string; name: string }[],
			activeColl: null as string | null,
			artistName: '',

			// 🎙️ 自动语音导览状态
			tourOn: false,
			tourIdx: -1,
			tourAudio: null as HTMLAudioElement | null,

			async init() {
				this.slug = parseArtistSlugFromUrl();
				if (!this.slug) {
					this.loading = false;
					return;
				}
				const all = await listAll();
				const mine = all.filter((p) => p.artistSlug === this.slug);
				this.photos = mine;

				if (mine.length > 0) {
					this.artistName = mine[0].meta.artistName || this.slug;
					const groups = groupByCollection(mine);
					this.collections = groups.map((g) => ({ slug: g.slug, name: g.name }));
				}
				this.loading = false;
				await this.$nextTick();
				renderGrid(this.filtered());
			},

			filtered() {
				if (!this.activeColl) return this.photos;
				return this.photos.filter((p) => p.collectionSlug === this.activeColl);
			},

			async selectCollection(coll: string | null) {
				this.activeColl = coll;
				await this.$nextTick();
				renderGrid(this.filtered());
			},

			/* ---------- 🎙️ 自动语音导览 (M3) ---------- */

			get narratableCount(): number {
				return this.filtered().filter((p) => !!p.narrationPath).length;
			},

			toggleTour() {
				if (this.tourOn) {
					this.stopTour();
				} else {
					this.startTour(0);
				}
			},

			startTour(fromIdx: number) {
				const list = this.filtered();
				const idx = list.findIndex((p, i) => i >= fromIdx && p.narrationPath);
				if (idx < 0) return;
				this.tourOn = true;
				this.playAt(idx);
			},

			stopTour() {
				this.tourOn = false;
				this.tourIdx = -1;
				if (this.tourAudio) {
					this.tourAudio.pause();
					this.tourAudio = null;
				}
				highlightTourCard(-1);
			},

			playAt(idx: number) {
				const list = this.filtered();
				const p = list[idx];
				if (!p) {
					this.stopTour();
					return;
				}
				const url = narrationUrl(p);
				if (!url) {
					// 这张没解说,跳到下一张
					this.advanceTour(idx + 1);
					return;
				}
				if (this.tourAudio) {
					this.tourAudio.pause();
					this.tourAudio = null;
				}
				this.tourIdx = idx;
				highlightTourCard(idx);
				const a = new Audio(url);
				a.addEventListener('ended', () => this.advanceTour(idx + 1));
				a.addEventListener('error', () => this.advanceTour(idx + 1));
				a.play().catch((err) => {
					console.warn('autoplay 被拦,等待用户交互', err);
				});
				this.tourAudio = a;
			},

			advanceTour(nextIdx: number) {
				if (!this.tourOn) return;
				const list = this.filtered();
				const idx = list.findIndex((p, i) => i >= nextIdx && p.narrationPath);
				if (idx < 0) {
					this.stopTour();
					return;
				}
				this.playAt(idx);
			},
		};
	}

	/** 给当前在播作品的卡片描个边,其它取消高亮 */
	function highlightTourCard(idx: number) {
		const grid = document.getElementById('photo-grid');
		if (!grid) return;
		grid.querySelectorAll<HTMLElement>('.photo-item').forEach((el, i) => {
			el.classList.toggle('ring-4', i === idx);
			el.classList.toggle('ring-violet-400', i === idx);
		});
	}

	function parseArtistSlugFromUrl(): string {
		// 优先 ?slug=xxx 用于 dev 预览（dev 模式没有 404 fallback）
		const params = new URLSearchParams(window.location.search);
		const fromQuery = params.get('slug');
		if (fromQuery) return fromQuery;

		// 否则从 pathname 取第一段：/<base>/<slug>/...
		const path = window.location.pathname.replace(/\/+$/, '');
		const baseEl = document.getElementById('artist-page');
		const base = (baseEl?.dataset.base || '/').replace(/\/+$/, '');
		let rest = path;
		if (base && rest.startsWith(base)) rest = rest.slice(base.length);
		rest = rest.replace(/^\/+/, '');
		const seg = rest.split('/')[0] || '';
		if (seg === '__artist__') return ''; // 占位路径
		const reserved = new Set(['', 'about', 'collections', 'upload', 'artists']);
		if (reserved.has(seg)) return '';
		return seg;
	}

	function renderGrid(photos: PhotoEntry[]) {
		const grid = document.getElementById('photo-grid');
		if (!grid) return;
		teardownGallery();
		grid.innerHTML = '';
		grid.removeAttribute('style');
		for (const p of photos) {
			const a = document.createElement('a');
			a.className = 'photo-item glightbox absolute transition-transform hover:scale-[1.02] hover:z-10';
			a.href = deliveryUrl(p, { width: 2000 });
			a.dataset.gallery = 'gallery1';
			a.dataset.type = 'image';
			if (p.meta.description) {
				a.dataset.glightbox = `title: ${p.meta.description}`;
			}

			const img = document.createElement('img');
			img.src = deliveryUrl(p, { width: 800 });
			img.srcset = srcSet(p);
			img.sizes = '(max-width: 768px) 50vw, 33vw';
			img.alt = p.meta.title || '';
			img.width = p.width;
			img.height = p.height;
			img.loading = 'lazy';
			img.className = 'w-full h-full object-cover rounded-sm shadow-sm hover:shadow-lg transition-shadow';
			a.appendChild(img);

			// 🎙️ 解说播放按钮:阻止冒泡,不触发 glightbox
			const url = narrationUrl(p);
			if (url) {
				const btn = document.createElement('button');
				btn.type = 'button';
				btn.className =
					'absolute bottom-2 right-2 px-2.5 py-1 rounded-full bg-black/70 hover:bg-violet-600 text-white text-xs font-medium backdrop-blur-sm transition-colors flex items-center gap-1';
				btn.dataset.narrationUrl = url;
				btn.innerHTML = '<span class="text-[10px]">▶</span> 听';
				btn.title = 'AI 合成语音解说';
				btn.addEventListener('click', (ev) => {
					ev.preventDefault();
					ev.stopPropagation();
					playSingleNarration(btn, url);
				});
				a.appendChild(btn);
			}

			grid.appendChild(a);
		}
		setupGallery();
	}

	/** 单张解说播放(非导览模式),按钮自己管自己 toggle */
	let _singleAudio: HTMLAudioElement | null = null;
	let _singleBtn: HTMLButtonElement | null = null;
	function playSingleNarration(btn: HTMLButtonElement, url: string) {
		const sameBtn = _singleBtn === btn;
		if (_singleAudio) {
			_singleAudio.pause();
			_singleAudio = null;
		}
		if (_singleBtn) {
			_singleBtn.innerHTML = '<span class="text-[10px]">▶</span> 听';
			_singleBtn.classList.remove('bg-violet-600');
		}
		if (sameBtn) {
			_singleBtn = null;
			return; // 第二次点同一个 → 停
		}
		const a = new Audio(url);
		a.addEventListener('ended', () => {
			btn.innerHTML = '<span class="text-[10px]">▶</span> 听';
			btn.classList.remove('bg-violet-600');
			if (_singleAudio === a) {
				_singleAudio = null;
				_singleBtn = null;
			}
		});
		a.addEventListener('error', () => {
			btn.innerHTML = '⚠️';
			if (_singleAudio === a) {
				_singleAudio = null;
				_singleBtn = null;
			}
		});
		btn.innerHTML = '<span class="text-[10px]">⏸</span> 停';
		btn.classList.add('bg-violet-600');
		a.play().catch(() => {
			btn.innerHTML = '<span class="text-[10px]">▶</span> 听';
			btn.classList.remove('bg-violet-600');
		});
		_singleAudio = a;
		_singleBtn = btn;
	}

	(window as any).artistPage = artistPage;
	document.addEventListener('alpine:init', () => {
		(window as any).Alpine?.data('artistPage', artistPage);
	});
</script>
