---
import MainLayout from '../layouts/MainLayout.astro';

const base = import.meta.env.BASE_URL;
---

<MainLayout>
	<section
		class="pt-32 pb-20"
		x-data="artistsListPage()"
		x-init="init()"
		data-base={base}
	>
		<div class="container-custom px-4">
			<div class="text-center mb-12">
				<h1 class="text-4xl md:text-5xl font-bold mb-4">艺术家</h1>
				<p class="text-gray-600">浏览所有创作者，点击卡片查看完整作品集</p>
			</div>

			<template x-if="loading">
				<div class="text-center py-20 text-gray-400">加载中…</div>
			</template>

			<template x-if="!loading && artists.length === 0">
				<div class="text-center py-20">
					<p class="text-gray-600 mb-6">还没有任何作品上传。</p>
					<a :href="`${base}/upload/`" class="px-6 py-3 bg-black text-white rounded inline-block">
						成为第一位 →
					</a>
				</div>
			</template>

			<template x-if="!loading && artists.length > 0">
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					<template x-for="a in artists" :key="a.href">
						<a
							:href="a.href"
							class="group block border border-gray-200 rounded-lg overflow-hidden hover:shadow-lg transition-shadow"
						>
							<div class="aspect-[4/3] bg-gray-100 overflow-hidden">
								<img
									:src="a.coverUrl"
									:alt="a.name"
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
									loading="lazy"
								/>
							</div>
							<div class="p-4">
								<h3 class="font-semibold text-lg" x-text="a.name"></h3>
								<p class="text-sm text-gray-500" x-text="`${a.photoCount} 张作品`"></p>
							</div>
						</a>
					</template>
				</div>
			</template>
		</div>
	</section>
</MainLayout>

<script>
	import { listAll, groupByArtist, deliveryUrl, artistHref } from '../lib/photos';

	function artistsListPage() {
		return {
			loading: true,
			base: '',
			artists: [] as { slug: string; name: string; photoCount: number; coverUrl: string; href: string }[],

			async init() {
				this.base = (document.documentElement.dataset.base || '').replace(/\/+$/, '');
				const all = await listAll();
				this.artists = groupByArtist(all).map((a) => ({
					slug: a.slug,
					name: a.name,
					photoCount: a.photoCount,
					coverUrl: deliveryUrl(a.coverPhoto, { width: 800 }),
					href: artistHref({ ownerHash: a.ownerHash, slug: a.slug }, this.base),
				}));
				this.loading = false;
			},
		};
	}

	(window as any).artistsListPage = artistsListPage;
	document.addEventListener('alpine:init', () => {
		(window as any).Alpine?.data('artistsListPage', artistsListPage);
	});
</script>
