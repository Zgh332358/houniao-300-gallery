---
import siteConfig from '../../site.config.mjs';

const title = siteConfig.title;
const tagline = siteConfig.tagline;
const base = import.meta.env.BASE_URL;
---

<!--
	Hero 备用版本（带背景图）。原模板默认使用 LandingHero-1.astro，
	若需启用此版本，请在 src/pages/index.astro 把 LandingHero-1 换为 LandingHero-2，
	并在下面的 backgroundImage 里替换为你自己的代表图。
	TODO: 把背景图换为候鸟 300 项目代表图
-->

<div
	class="absolute top-[80px] bottom-[120px] left-0 right-0 z-0"
	style={{
		backgroundImage: 'none',
		backgroundColor: '#f3f4f6',
		backgroundSize: 'cover',
		backgroundPosition: 'center',
		backgroundRepeat: 'no-repeat',
		opacity: 0.6,
	}}
>
</div>
<div class="container text-left mb-32 relative z-10">
	<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
		{title}
	</h1>
	<p class="mt-4 text-base md:text-lg text-gray-700">{tagline}</p>
	<a
		href=`${base}/collections`
		class="mt-8 inline-block px-6 py-3 border-2 border-black rounded-md
                      hover:bg-black hover:text-white transition-all duration-300
                      text-sm md:text-base font-medium
                      transform hover:scale-105 active:scale-95"
	>
		浏览作品
	</a>
</div>
