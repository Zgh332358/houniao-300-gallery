---
/**
 * 4 步流程预览 — 在首页第二屏让访客在点「开始」之前就知道路径有多长。
 * 纯展示组件,没交互。
 */

const base = import.meta.env.BASE_URL;

const steps = [
	{
		n: 1,
		title: '登录 + 你是谁',
		hint: '手机号登录,填个名字和联系方式,配好 AI 助手',
		emoji: '✍️',
	},
	{
		n: 2,
		title: '作品集',
		hint: '给这一组作品起个名字,比如「夜色街拍」',
		emoji: '🗂️',
	},
	{
		n: 3,
		title: '选图 + AI 文案',
		hint: '拖图进来,AI 自动写中英标题、描述、策展评语',
		emoji: '🖼️',
	},
	{
		n: 4,
		title: '发布',
		hint: '拿到属于你的 URL,直接分享',
		emoji: '✅',
	},
];
---

<section class="py-16 md:py-24 bg-gray-50">
	<div class="container-custom max-w-5xl mx-auto px-4">
		<div class="text-center mb-12">
			<p class="text-sm text-violet-600 font-medium tracking-wider uppercase mb-2">
				4 步 · 约 3 分钟
			</p>
			<h2 class="text-3xl md:text-4xl font-bold mb-3">从你打开网站,到你的展厅上线</h2>
			<p class="text-gray-600">每一步页面顶部都会告诉你走到哪了 — 不用记</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-2">
			{
				steps.map((s, i) => (
					<div class="relative">
						<div class="bg-white border border-gray-200 rounded-lg p-5 h-full flex flex-col">
							<div class="flex items-center gap-3 mb-3">
								<div class="w-9 h-9 rounded-full bg-violet-100 text-violet-700 flex items-center justify-center text-sm font-semibold">
									{s.n}
								</div>
								<div class="text-2xl">{s.emoji}</div>
							</div>
							<h3 class="font-semibold text-base mb-1">{s.title}</h3>
							<p class="text-xs text-gray-500 leading-relaxed">{s.hint}</p>
						</div>
						{i < steps.length - 1 && (
							<div class="hidden md:block absolute top-1/2 -right-1 w-2 h-px bg-gray-300 -translate-y-1/2" />
						)}
					</div>
				))
			}
		</div>

		<div class="mt-10 text-center">
			<a
				href={`${base}/upload/`}
				class="inline-block px-8 py-3 bg-black text-white rounded-md font-medium hover:bg-violet-600 transition-colors"
			>
				准备好了 · 开始 →
			</a>
			<p class="text-xs text-gray-400 mt-3">先准备好作品文件,再开始 · 几句话介绍每件作品</p>
		</div>
	</div>
</section>
