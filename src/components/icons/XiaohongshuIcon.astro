---
/**
 * 小红书 Icon · 自定义 SVG（lucide 没有原生小红书图标）
 * 风格：圆角方框 + 内部"小红书"三字，沿用 currentColor 与 lucide 系视觉一致。
 * 用法：<XiaohongshuIcon size={20} />
 */
interface Props {
	size?: number;
}
const { size = 24 } = Astro.props;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.8"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-label="小红书"
>
	<rect x="2.5" y="2.5" width="19" height="19" rx="4"></rect>
	<text
		x="12"
		y="13.5"
		font-family="'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', system-ui, sans-serif"
		font-size="5.2"
		font-weight="900"
		fill="currentColor"
		stroke="none"
		text-anchor="middle"
		dominant-baseline="middle">小红书</text
	>
</svg>
