---
import '../styles/global.css';
import siteConfig from '../../site.config.mjs';
import Footer from '../components/Footer.astro';
import NavBar from '../components/NavBar.astro';
import { getMode } from '../lib/photos';

const owner = siteConfig.owner;
const base = import.meta.env.BASE_URL;
const mode = getMode();
---

<html lang="en" class="h-full" data-base={base}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>

		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{owner}</title>
	</head>
	<body>
		{
			mode === 'mock' && (
				<div class="bg-blue-600 text-white text-center text-xs py-1.5 px-4 relative z-40">
					🎨 演示模式 · 当前用预设示例数据 ·
					<a href={`${base}/upload/`} class="underline ml-1 font-medium">
						去 /upload 试试上传
					</a>
				</div>
			)
		}
		<NavBar />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<script>
	import Alpine from 'alpinejs';
	(window as any).Alpine = Alpine;
	// 用 'load' 事件等所有 deferred module + 资源都加载完，
	// 确保 page-level script 已经把 xxxApp 挂到 window 上。
	if (document.readyState === 'complete') {
		Alpine.start();
	} else {
		window.addEventListener('load', () => Alpine.start());
	}
</script>
