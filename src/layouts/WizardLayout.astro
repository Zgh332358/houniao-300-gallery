---
/**
 * 上传向导每一步页面的统一壳。提供:
 *   - NavBar(继承 MainLayout) → 顶部 ~64px 是 fixed 的,WizardLayout 必须给它让位
 *   - sticky 进度条:跟着滚动一直贴在 NavBar 下方
 *   - 内容区(slot)
 *   - 内容末尾的「上一步 / 下一步」按钮(inline,大,显眼) ——
 *     不再用 fixed bottom 浮条,因为找不到
 *
 * 子页面在 init 完成后调 window.__wizardSetNextEnabled(boolean) 开关下一步按钮。
 */

import MainLayout from './MainLayout.astro';
import UploadStepper from '../components/UploadStepper.astro';
import { STEP_ORDER, STEP_LABEL, stepHref, type StepName } from '../lib/wizard';

interface Props {
	step: StepName;
	title?: string;
	subtitle?: string;
}

const { step, title, subtitle } = Astro.props;
const base = import.meta.env.BASE_URL;

const idx = STEP_ORDER.indexOf(step);
const prev = idx > 0 ? STEP_ORDER[idx - 1] : null;
const next = idx < STEP_ORDER.length - 1 ? STEP_ORDER[idx + 1] : null;

const prevHref = prev ? stepHref(base, prev) : '';
const nextHref = next ? stepHref(base, next) : '';
---

<MainLayout>
	<!-- pt-20/24 把内容压到 NavBar 下方 — 不然标题被 fixed NavBar 盖住一半 -->
	<div class="pt-20 md:pt-24">
		<UploadStepper current={step} />

		<section class="pt-8 pb-16" data-wizard-step={step}>
			<div class="container-custom max-w-3xl mx-auto px-4">
				<header class="mb-8">
					<p class="text-xs text-violet-600 font-medium tracking-widest uppercase mb-1">
						第 {idx + 1} / {STEP_ORDER.length} 步
					</p>
					<h1 class="text-3xl md:text-4xl font-bold mb-2 leading-tight">
						{title || STEP_LABEL[step]}
					</h1>
					{subtitle && <p class="text-gray-600 leading-relaxed">{subtitle}</p>}
				</header>

				<slot />

				<!-- 内容末尾的导航 — 大、紫、显眼;不要藏在 fixed bottom 里 -->
				<div
					class="mt-12 pt-8 border-t border-gray-200 flex items-center justify-between gap-3 flex-wrap"
				>
					{
						prev ? (
							<a
								href={prevHref}
								class="px-5 py-3 text-sm text-gray-600 hover:text-gray-900 hover:underline flex items-center gap-1"
							>
								← {STEP_LABEL[prev]}
							</a>
						) : (
							<span />
						)
					}

					{
						next ? (
							<a
								id="wizard-next"
								href={nextHref}
								class="wizard-next-btn inline-flex items-center gap-2 px-7 py-3.5 bg-violet-600 text-white rounded-lg font-semibold text-base shadow-lg shadow-violet-500/20 hover:bg-violet-700 hover:shadow-violet-500/30 transition-all pointer-events-none opacity-40"
								data-next-step={next}
							>
								下一步:{STEP_LABEL[next]} →
							</a>
						) : (
							<span class="text-sm text-gray-500">最后一步 — 在内容里点「开始发布」</span>
						)
					}
				</div>
			</div>
		</section>
	</div>
</MainLayout>

<script>
	declare global {
		interface Window {
			__wizardSetNextEnabled?: (enabled: boolean) => void;
		}
	}
	const btn = document.getElementById('wizard-next');
	window.__wizardSetNextEnabled = (enabled: boolean) => {
		if (!btn) return;
		if (enabled) {
			btn.classList.remove('pointer-events-none', 'opacity-40');
		} else {
			btn.classList.add('pointer-events-none', 'opacity-40');
		}
	};
</script>
