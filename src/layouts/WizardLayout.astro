---
/**
 * 上传向导每一步页面的统一壳。提供:
 *   - NavBar(继承 MainLayout)
 *   - Sticky 进度条
 *   - 内容区(slot)
 *   - 底部固定的「上一步 / 下一步」按钮
 *
 * 子页面的下一步是否可点,通过给 next 按钮加 :disabled 与 _wizard_next 函数控制 ——
 * 简单起见,这里只渲染 href 链接;子页面用 JS 在合适时机移除 .pointer-events-none 等。
 */

import MainLayout from './MainLayout.astro';
import UploadStepper from '../components/UploadStepper.astro';
import { STEP_ORDER, STEP_LABEL, stepHref, type StepName } from '../lib/wizard';

interface Props {
	step: StepName;
	title?: string;
	subtitle?: string;
}

const { step, title, subtitle } = Astro.props;
const base = import.meta.env.BASE_URL;

const idx = STEP_ORDER.indexOf(step);
const prev = idx > 0 ? STEP_ORDER[idx - 1] : null;
const next = idx < STEP_ORDER.length - 1 ? STEP_ORDER[idx + 1] : null;

const prevHref = prev ? stepHref(base, prev) : '';
const nextHref = next ? stepHref(base, next) : '';
---

<MainLayout>
	<UploadStepper current={step} />

	<section class="pt-6 pb-32" data-wizard-step={step}>
		<div class="container-custom max-w-3xl mx-auto px-4">
			<header class="mb-8">
				<p class="text-xs text-violet-600 font-medium tracking-widest uppercase mb-1">
					第 {idx + 1} / {STEP_ORDER.length} 步
				</p>
				<h1 class="text-3xl md:text-4xl font-bold mb-2">{title || STEP_LABEL[step]}</h1>
				{subtitle && <p class="text-gray-600">{subtitle}</p>}
			</header>

			<slot />
		</div>
	</section>

	<!-- 底部 sticky:上一步 / 下一步 -->
	<nav class="fixed bottom-0 left-0 right-0 z-30 bg-white/95 backdrop-blur border-t border-gray-200">
		<div class="container-custom max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
			{
				prev ? (
					<a
						href={prevHref}
						class="px-4 py-2 text-sm text-gray-600 hover:text-gray-900 flex items-center gap-1"
					>
						← {STEP_LABEL[prev]}
					</a>
				) : (
					<span />
				)
			}

			{
				next ? (
					<a
						id="wizard-next"
						href={nextHref}
						class="wizard-next-btn px-6 py-2.5 bg-black text-white rounded-md font-medium hover:bg-violet-600 transition-colors flex items-center gap-2 pointer-events-none opacity-40"
						data-next-step={next}
					>
						下一步:{STEP_LABEL[next]} →
					</a>
				) : (
					<span />
				)
			}
		</div>
	</nav>
</MainLayout>

<script>
	/**
	 * 让所有 wizard 子页面在 init 完成后调一下 window.__wizardSetNextEnabled(true/false)
	 * 来开关下一步按钮。
	 */
	declare global {
		interface Window {
			__wizardSetNextEnabled?: (enabled: boolean) => void;
		}
	}
	const btn = document.getElementById('wizard-next');
	window.__wizardSetNextEnabled = (enabled: boolean) => {
		if (!btn) return;
		if (enabled) {
			btn.classList.remove('pointer-events-none', 'opacity-40');
		} else {
			btn.classList.add('pointer-events-none', 'opacity-40');
		}
	};
</script>
